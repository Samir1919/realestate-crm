<%- include('partials/header') %>
<%- include('partials/sidebar') %>

<!-- SortableJS Needed Only for Kanban functionality -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/Sortable/1.15.0/Sortable.min.js"></script>

<h1 class="text-2xl font-bold mb-6">Property Sales Pipeline (Kanban)</h1>

<div class="grid grid-cols-1 md:grid-cols-5 gap-4">
    <% const stages = ['New Lead', 'Property Viewing', 'Negotiation', 'Contract Signed', 'Closed']; %>
    <% stages.forEach(stage => { %>
        <div class="bg-gray-200 p-4 rounded-xl min-h-[550px] flex flex-col">
            <h3 class="font-bold text-sm uppercase text-gray-600 mb-4 tracking-wider"><%= stage %></h3>
            
            <!-- Target dropzone -->
            <div id="<%= stage.replace(/\s+/g, '-') %>" class="kanban-col space-y-3 flex-1 min-h-[450px]">
                <% leads.filter(l => l.stage === stage).forEach(lead => { %>
                    <div class="bg-white p-4 rounded-lg shadow-sm border border-gray-100 cursor-grab hover:shadow transition active:cursor-grabbing" data-id="<%= lead._id %>">
                        <h4 class="font-bold text-gray-900"><%= lead.name %></h4>
                        <p class="text-xs text-gray-500 mt-1">
                            <i class="fa-solid fa-location-dot text-blue-500"></i> <%= lead.propertyInterest.location || 'Anywhere' %>
                        </p>
                        <div class="flex justify-between items-center mt-3 pt-2 border-t border-gray-50">
                            <span class="text-[10px] font-bold uppercase px-2 py-0.5 rounded bg-slate-100 text-slate-700"><%= lead.leadType %></span>
                            <span class="text-xs font-bold text-emerald-600"><%= lead.propertyInterest.budget || 'N/A' %></span>
                        </div>
                    </div>
                <% }) %>
            </div>
        </div>
    <% }) %>
</div>

<script>
    // Initialize Sortable on every pipeline column
    document.querySelectorAll('.kanban-col').forEach(col => {
        new Sortable(col, {
            group: 'realestate-pipeline',
            animation: 150,
            ghostClass: 'bg-blue-50', 
            onEnd: async function (evt) {
                const leadId = evt.item.getAttribute('data-id');
                const newStage = evt.to.id.replace(/-/g, ' ');

                // Fire background update via fetch API
                try {
                    const response = await fetch('/leads/update-stage', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ leadId, stage: newStage })
                    });
                    const data = await response.json();
                    if(!data.success) alert("Failed to update status on server.");
                } catch(err) {
                    console.error("Network error updating board:", err);
                }
            }
        });
    });
</script>

<%- include('partials/footer') %>