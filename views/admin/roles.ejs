<%- include('../partials/header') %>
    <%- include('../partials/sidebar') %>

        <div class="w-full min-w-0 overflow-x-hidden">
            <div class="safe-container mx-auto w-full px-4 sm:px-6 lg:px-8 py-6 space-y-6 max-w-[1600px]">
                <%- include('../partials/ui/page-header', { title: 'Roles & Permissions' ,
                    subtitle: 'Create/update roles and permission sets for your CRM users' }) %>

                    <% if (success) { %>
                        <%- include('../partials/ui/flash-message', { variant: 'success' , message: success }) %>
                            <% } %>
                                <% if (error) { %>
                                    <%- include('../partials/ui/flash-message', { variant: 'error' , message: error })
                                        %>
                                        <% } %>

                                            <div class="grid grid-cols-1 gap-6 xl:grid-cols-3">
                                                <div class="crm-card p-5">
                                                    <h2 class="text-lg font-semibold text-slate-900">Create Role</h2>
                                                    <form method="POST" action="/admin/roles/create"
                                                        class="mt-4 space-y-3">
                                                        <div>
                                                            <label
                                                                class="mb-1 block text-sm font-medium text-slate-700">Role
                                                                Name
                                                                (lowercase)</label>
                                                            <input name="name" type="text" placeholder="e.g. telecaller"
                                                                required
                                                                class="w-full rounded-xl border border-slate-300 px-3 py-2.5 text-sm outline-none transition focus:border-blue-500 focus:ring-2 focus:ring-blue-100" />
                                                        </div>
                                                        <button type="submit"
                                                            class="crm-btn-primary w-full rounded-xl px-4 py-2.5 text-sm font-semibold text-white">Create
                                                            Role</button>
                                                    </form>
                                                </div>

                                                <div class="crm-card p-5 xl:col-span-2">
                                                    <h2 class="text-lg font-semibold text-slate-900">Permission Catalog
                                                    </h2>
                                                    <form method="POST" action="/admin/permissions/create"
                                                        class="mt-4 grid grid-cols-1 gap-3 md:grid-cols-3">
                                                        <input name="key" type="text" placeholder="permission_key"
                                                            required
                                                            class="rounded-xl border border-slate-300 px-3 py-2.5 text-sm outline-none transition focus:border-blue-500 focus:ring-2 focus:ring-blue-100" />
                                                        <input name="description" type="text" placeholder="Description"
                                                            class="rounded-xl border border-slate-300 px-3 py-2.5 text-sm outline-none transition focus:border-blue-500 focus:ring-2 focus:ring-blue-100" />
                                                        <button type="submit"
                                                            class="crm-btn-primary rounded-xl px-4 py-2.5 text-sm font-semibold text-white">Add
                                                            Permission</button>
                                                    </form>

                                                    <div class="mt-4 space-y-3 max-h-[280px] overflow-y-auto pr-1">
                                                        <% permissionCatalog.forEach((permission)=> { %>
                                                            <div class="rounded-xl border border-slate-200 p-3">
                                                                <form method="POST"
                                                                    action="/admin/permissions/<%= permission._id %>/update"
                                                                    class="grid grid-cols-1 gap-2 md:grid-cols-12 md:items-center">
                                                                    <input name="key" value="<%= permission.key %>"
                                                                        <%=permission.system ? 'readonly' : '' %>
                                                                    class="rounded-lg
                                                                    border border-slate-300 px-3 py-2 text-sm
                                                                    md:col-span-4" />
                                                                    <input name="description"
                                                                        value="<%= permission.description || '' %>"
                                                                        <%=permission.system ? 'readonly' : '' %>
                                                                    class="rounded-lg
                                                                    border border-slate-300 px-3 py-2 text-sm
                                                                    md:col-span-6" />
                                                                    <button type="submit" <%=permission.system
                                                                        ? 'disabled' : '' %>
                                                                        class="rounded-lg bg-slate-800 px-3 py-2 text-sm
                                                                        font-semibold text-white
                                                                        disabled:cursor-not-allowed
                                                                        disabled:opacity-40 md:col-span-2">Save</button>
                                                                </form>
                                                                <% if (!permission.system) { %>
                                                                    <form method="POST"
                                                                        action="/admin/permissions/<%= permission._id %>/delete"
                                                                        class="mt-2">
                                                                        <button type="submit"
                                                                            class="rounded-lg border border-red-200 bg-red-50 px-3 py-1.5 text-xs font-semibold text-red-700 hover:bg-red-100">Delete</button>
                                                                    </form>
                                                                    <% } %>
                                                            </div>
                                                            <% }) %>
                                                                <% if (permissionCatalog.length===0) { %>
                                                                    <p class="text-sm text-slate-400">No permissions
                                                                        defined yet.
                                                                    </p>
                                                                    <% } %>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="grid grid-cols-1 gap-2.5 lg:hidden sm:grid-cols-2 sm:gap-3">
                                                <% roles.forEach((role)=> { %>
                                                    <div class="crm-card rounded-2xl p-3 sm:p-3.5">
                                                        <div class="flex items-center justify-between gap-3">
                                                            <span
                                                                class="inline-flex rounded-full border px-2 py-0.5 text-xs font-semibold <%= role.system ? 'border-violet-200 bg-violet-50 text-violet-700' : 'border-slate-200 bg-slate-100 text-slate-700' %>">
                                                                <%= role.name %>
                                                            </span>
                                                            <% if (role.system || role.name==='admin' ||
                                                                role.name==='viewer' ) { %>
                                                                <span class="text-xs text-slate-400">System role</span>
                                                                <% } %>
                                                        </div>

                                                        <form method="POST" action="/admin/roles/<%= role._id %>/update"
                                                            class="mt-2 flex items-center gap-1.5 sm:mt-2.5">
                                                            <input name="name" value="<%= role.name %>"
                                                                class="w-full rounded-lg border border-slate-300 px-2 py-1.5 text-sm"
                                                                <%=role.system && role.name==='admin' ? 'readonly' : ''
                                                                %> />
                                                            <button type="submit"
                                                                class="shrink-0 rounded-lg bg-slate-800 px-2 py-1.5 text-sm font-semibold text-white">Save</button>
                                                        </form>

                                                        <form method="POST"
                                                            action="/admin/roles/<%= role._id %>/permissions"
                                                            class="mt-2 space-y-1.5 sm:mt-2.5">
                                                            <div
                                                                class="grid grid-cols-2 gap-1 sm:grid-cols-3 sm:gap-1.5">
                                                                <% permissionCatalog.forEach((permission)=> { %>
                                                                    <label
                                                                        class="flex items-center gap-1 rounded-lg border border-slate-200 px-1.5 py-1 text-[10px] text-slate-700 sm:px-2 sm:py-1.5 sm:text-[11px]">
                                                                        <input type="checkbox" name="permissions"
                                                                            class="h-3 w-3"
                                                                            value="<%= permission.key %>"
                                                                            <%=(role.permissions ||
                                                                            []).includes(permission.key) ? 'checked'
                                                                            : '' %> />
                                                                        <span class="safe-truncate">
                                                                            <%= permission.key %>
                                                                        </span>
                                                                    </label>
                                                                    <% }) %>
                                                            </div>
                                                            <button type="submit"
                                                                class="crm-btn-primary rounded-lg px-2 py-1.5 text-sm font-semibold text-white">Update
                                                                Permissions</button>
                                                        </form>

                                                        <% if (!role.system && role.name !=='admin' && role.name
                                                            !=='viewer' ) { %>
                                                            <form method="POST"
                                                                action="/admin/roles/<%= role._id %>/delete"
                                                                class="mt-1.5">
                                                                <button type="submit"
                                                                    class="rounded-lg border border-red-200 bg-red-50 px-2 py-1.5 text-sm font-semibold text-red-700 hover:bg-red-100">Delete</button>
                                                            </form>
                                                            <% } %>
                                                    </div>
                                                    <% }) %>

                                                        <% if (roles.length===0) { %>
                                                            <div
                                                                class="rounded-2xl border border-slate-200 bg-white p-6 text-center text-slate-400 sm:col-span-2">
                                                                No roles found.
                                                            </div>
                                                            <% } %>
                                            </div>

                                            <div class="crm-table-shell hidden lg:block">
                                                <div class="w-full min-w-0 overflow-x-auto">
                                                    <table class="w-full min-w-[920px] text-sm">
                                                        <thead>
                                                            <tr
                                                                class="bg-slate-50 text-slate-500 text-xs uppercase tracking-wide">
                                                                <th class="p-3 text-left font-semibold">Role</th>
                                                                <th class="p-3 text-left font-semibold">Rename</th>
                                                                <th class="p-3 text-left font-semibold">Permissions</th>
                                                                <th class="p-3 text-left font-semibold">Delete</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            <% roles.forEach((role)=> { %>
                                                                <tr class="border-t border-slate-100 align-top">
                                                                    <td class="p-3">
                                                                        <span
                                                                            class="inline-flex rounded-full border px-2 py-0.5 text-xs font-semibold <%= role.system ? 'border-violet-200 bg-violet-50 text-violet-700' : 'border-slate-200 bg-slate-100 text-slate-700' %>">
                                                                            <%= role.name %>
                                                                        </span>
                                                                    </td>
                                                                    <td class="p-3">
                                                                        <form method="POST"
                                                                            action="/admin/roles/<%= role._id %>/update"
                                                                            class="flex items-center gap-2">
                                                                            <input name="name" value="<%= role.name %>"
                                                                                class="rounded-lg border border-slate-300 px-3 py-2 text-sm"
                                                                                <%=role.system && role.name==='admin'
                                                                                ? 'readonly' : '' %> />
                                                                            <button type="submit"
                                                                                class="rounded-lg bg-slate-800 px-3 py-2 text-sm font-semibold text-white">Save</button>
                                                                        </form>
                                                                    </td>
                                                                    <td class="p-3">
                                                                        <form method="POST"
                                                                            action="/admin/roles/<%= role._id %>/permissions"
                                                                            class="space-y-2">
                                                                            <div class="grid grid-cols-2 gap-2">
                                                                                <%
                                                                                    permissionCatalog.forEach((permission)=>
                                                                                    { %>
                                                                                    <label
                                                                                        class="flex items-center gap-2 rounded-lg border border-slate-200 px-2 py-1.5 text-xs text-slate-700">
                                                                                        <input type="checkbox"
                                                                                            name="permissions"
                                                                                            value="<%= permission.key %>"
                                                                                            <%=(role.permissions ||
                                                                                            []).includes(permission.key)
                                                                                            ? 'checked' : '' %> />
                                                                                        <span>
                                                                                            <%= permission.key %>
                                                                                        </span>
                                                                                    </label>
                                                                                    <% }) %>
                                                                            </div>
                                                                            <button type="submit"
                                                                                class="crm-btn-primary rounded-lg px-3 py-2 text-sm font-semibold text-white">Update
                                                                                Permissions</button>
                                                                        </form>
                                                                    </td>
                                                                    <td class="p-3">
                                                                        <% if (!role.system && role.name !=='admin' &&
                                                                            role.name !=='viewer' ) { %>
                                                                            <form method="POST"
                                                                                action="/admin/roles/<%= role._id %>/delete">
                                                                                <button type="submit"
                                                                                    class="rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-semibold text-red-700 hover:bg-red-100">Delete
                                                                                    Role</button>
                                                                            </form>
                                                                            <% } else { %>
                                                                                <span
                                                                                    class="text-xs text-slate-400">System
                                                                                    role</span>
                                                                                <% } %>
                                                                    </td>
                                                                </tr>
                                                                <% }) %>
                                                                    <% if (roles.length===0) { %>
                                                                        <tr>
                                                                            <td colspan="4"
                                                                                class="p-8 text-center text-slate-400">
                                                                                No roles found.</td>
                                                                        </tr>
                                                                        <% } %>
                                                        </tbody>
                                                    </table>
                                                </div>
                                            </div>
            </div>
        </div>

        <%- include('../partials/footer') %>