                                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm bg-white">
                                <option value="">সিলেক্ট করুন</option>
                                <option value="Own Living">Own Living</option>
                                <option value="Investment">Investment</option>
                                <option value="Rental Income">Rental Income</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">উৎস (Source) <span
                                    class="text-red-500">*</span></label>
                            <select name="source" required
                                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm bg-white">
                                <option value="website">Website</option>
                                <option value="facebook">Facebook</option>
                                <option value="google">Google</option>
                                <option value="whatsapp">Whatsapp</option>
                                <option value="phone">Phone</option>
                                <option value="referral">Referral</option>
                                <option value="walk in">Walk In</option>
                            </select>
                        </div>
                    </div>

                    <!-- সেকশন ৪: ট্র্যাকিং ও ফলো-আপ -->
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1"> can অগ্রধিকার
                                (Priority)</label>
