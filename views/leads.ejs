                    </div>

                    <!-- মোডাল ফুটার বাটন -->
                    <div class="flex justify-end space-x-3 border-t border-gray-100 pt-4">
                        <button type="button" id="cancelModalBtn"
                            class="bg-gray-200 hover:bg-gray-300 text-gray-700 px-5 py-2 rounded-lg text-sm font-medium transition">বাতিল</button>
