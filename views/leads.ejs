        <!-- lead add button form -->
        <script>
            const openModalBtn = document.getElementById('openModalBtn');
            const closeModalBtn = document.getElementById('closeModalBtn');
            const cancelModalBtn = document.getElementById('cancelModalBtn');
            const leadModal = document.getElementById('leadModal');

            function openModal() {
                leadModal.classList.remove('hidden');
                document.body.style.overflow = 'hidden'; // মোডাল খুললে পেজ স্ক্রল বন্ধ থাকবে
            }

            function closeModal() {
                leadModal.classList.add('hidden');
                document.body.style.overflow = 'auto'; // মোডাল বন্ধ হলে পেজ স্ক্রল চালু হবে
            }

            openModalBtn.addEventListener('click', openModal);
            closeModalBtn.addEventListener('click', closeModal);
            cancelModalBtn.addEventListener('click', closeModal);

            // মোডালের বাইরের ফাঁকা জায়গায় ক্লিক করলে বন্ধ হবে
            leadModal.addEventListener('click', (e) => {
                if (e.target === leadModal) {
                    closeModal();
                }
            });
        </script>

        <!-- lead edit button form -->
        <script>
            function openEditModal(lead) {
                const modal = document.getElementById('editLeadModal');
                const form = document.getElementById('editLeadForm');

                // এখানে আপনার ব্যাকএন্ড রাউট অনুযায়ী আপডেট URL সেট হবে
                form.action = `/leads/update/${lead._id}`;

                // ফর্ম ইনপুটে ডাটা অটো সেট করার লজিক
                document.getElementById('edit_customerName').value = lead.customerName || '';
                document.getElementById('edit_phone').value = lead.phone || '';
                document.getElementById('edit_preferredLocation').value = lead.preferredLocation || '';
                document.getElementById('edit_propertyType').value = lead.propertyType || '';
                document.getElementById('edit_budgetMin').value = lead.budgetMin || '';
                document.getElementById('edit_budgetMax').value = lead.budgetMax || '';
                document.getElementById('edit_preferredSize').value = lead.preferredSize || '';
                document.getElementById('edit_bedrooms').value = lead.bedrooms || '';
                document.getElementById('edit_purpose').value = lead.purpose || '';
                document.getElementById('edit_source').value = lead.source || '';
                document.getElementById('edit_priority').value = lead.priority || '';
                document.getElementById('edit_status').value = lead.status || 'new';
                document.getElementById('edit_messageNote').value = lead.messageNote || '';

                // ডেট ফরম্যাটিং (YYYY-MM-DD ফরম্যাটে ইনপুটে বসানোর জন্য)
                if (lead.followUpDate) {
                    const date = new Date(lead.followUpDate);
                    const formattedDate = date.toISOString().split('T')[0];
                    document.getElementById('edit_followUpDate').value = formattedDate;
                } else {
                    document.getElementById('edit_followUpDate').value = '';
                }

                // মোডাল ওপেন করার অ্যানিমেশন ইফেক্ট
                modal.classList.remove('hidden');
                setTimeout(() => {
                    modal.children[0].classList.remove('scale-95');
                }, 10);
            }

            function closeEditModal() {
                const modal = document.getElementById('editLeadModal');
                modal.children[0].classList.add('scale-95');
                setTimeout(() => {
                    modal.classList.add('hidden');
                }, 150);
            }

            // মোডালের বাইরে ব্যাকড্রপে ক্লিক করলে যেন মোডাল বন্ধ হয়ে যায়
            window.onclick = function (event) {
                const modal = document.getElementById('editLeadModal');
                if (event.target == modal) {
                    closeEditModal();
                }
            }
        </script>

        <!-- lead delete button form -->
        <script>
            function openDeleteModal(leadId) {
                const modal = document.getElementById('deleteLeadModal');
                const form = document.getElementById('deleteLeadForm');

                // ব্যাকএন্ডের ডিলিট রাউট অনুযায়ী অ্যাকশন URL সেট হবে
                // সাধারণত এক্সপ্রেস-এ ডিলিট করার জন্য আমরা POST বা DELETE মেথড ব্যবহার করি
                form.action = `/leads/delete/${leadId}`;

                // মোডাল ওপেন অ্যানিমেশন
                modal.classList.remove('hidden');
                setTimeout(() => {
                    modal.children[0].classList.remove('scale-95');
                }, 10);
            }

            function closeDeleteModal() {
                const modal = document.getElementById('deleteLeadModal');
                modal.children[0].classList.add('scale-95');
                setTimeout(() => {
                    modal.classList.add('hidden');
                }, 150);
            }

            // আগের window.onclick ফাংশনটি আপডেট করে নিন যাতে দুই মোডালের বাইরেই কাজ করে:
            window.onclick = function (event) {
                const editModal = document.getElementById('editLeadModal');
                const deleteModal = document.getElementById('deleteLeadModal');

                if (event.target == editModal) {
                    closeEditModal();
                }
                if (event.target == deleteModal) {
                    closeDeleteModal();
                }
            }

        </script>



