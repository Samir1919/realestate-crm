                    <!-- সেকশন ১: কাস্টমার সংক্রান্ত তথ্য -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">গ্রাহকের নাম <span
                                    class="text-red-500">*</span></label>
