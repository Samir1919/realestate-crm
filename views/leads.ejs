                    class="flex items-center justify-between border-b border-gray-200 px-6 py-4 sticky top-0 bg-white z-10">
                    <h3 class="text-xl font-bold text-gray-800">নতুন গ্রাহকের তথ্য (Lead Form)</h3>
                    <button id="closeModalBtn"
                        class="text-gray-400 hover:text-gray-600 text-2xl font-semibold">&times;</button>
