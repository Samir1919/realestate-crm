</div> <!-- Closing Main Content Area Wrapper from sidebar.ejs -->
</div> <!-- Closing Main layout row container from header.ejs -->

<script>
    const sidebar = document.getElementById('sidebar');
    const toggleBtn = document.getElementById('toggle-sidebar');
    const openBtn = document.getElementById('open-sidebar');
    const logoText = document.getElementById('logo-text');
    const footerText = document.getElementById('sidebar-footer');
    const labels = document.querySelectorAll('.sidebar-label');

    function toggleSidebar() {
        if (window.innerWidth >= 768) {
            if (sidebar.classList.contains('w-64')) {
                sidebar.classList.remove('w-64');
                sidebar.classList.add('w-16');

                logoText.classList.add('hidden');
                footerText.classList.add('hidden');
                labels.forEach(lbl => lbl.classList.add('hidden'));
            } else {
                sidebar.classList.remove('w-16');
                sidebar.classList.add('w-64');

                logoText.classList.remove('hidden');
                footerText.classList.remove('hidden');
                labels.forEach(lbl => lbl.classList.remove('hidden'));
            }
        } else {
            if (sidebar.classList.contains('w-64')) {
                sidebar.classList.remove('w-64');
                sidebar.classList.add('w-0');
                openBtn.classList.remove('hidden');
            } else {
                sidebar.classList.remove('w-0');
                sidebar.classList.add('w-64');
                openBtn.classList.add('hidden');
            }
        }
    }

    toggleBtn.addEventListener('click', toggleSidebar);
    openBtn.addEventListener('click', toggleSidebar);

    function checkScreenSize() {
        logoText.classList.remove('hidden');
        footerText.classList.remove('hidden');
        labels.forEach(lbl => lbl.classList.remove('hidden'));

        if (window.innerWidth >= 768) {
            sidebar.classList.remove('w-0', 'fixed');
            sidebar.classList.add('w-64', 'relative');
            openBtn.classList.add('hidden');
        } else {
            sidebar.classList.remove('w-64', 'w-16', 'relative');
            sidebar.classList.add('w-0', 'fixed');
            openBtn.classList.remove('hidden');
        }
    }

    window.addEventListener('resize', checkScreenSize);
    window.addEventListener('DOMContentLoaded', checkScreenSize);
</script>

</body>

</html>
