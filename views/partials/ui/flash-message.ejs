<% const palette=variant==='error' ? 'border-red-200 bg-red-50 text-red-700' : variant==='warning'
    ? 'border-amber-200 bg-amber-50 text-amber-700' : 'border-emerald-200 bg-emerald-50 text-emerald-700' ; %>
    <div class="rounded-2xl border px-4 py-3 text-sm font-medium <%= palette %>">
        <%= message %>
    </div>