<%- include('partials/header') %>
<%- include('partials/sidebar') %>

<h2 class="text-2xl font-bold mb-6">CRM Analytics Overview</h2>

<!-- STATS ROW -->
<div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
    <!-- Total Leads Card -->
    <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100 flex items-center justify-between">
        <div>
            <p class="text-sm font-semibold text-gray-500 uppercase tracking-wider">Total Leads</p>
            <h3 class="text-3xl font-bold mt-1 text-gray-900"><%= leads.length %></h3>
        </div>
        <div class="p-3 bg-blue-50 text-blue-600 rounded-lg text-xl">
            <i class="fa-solid fa-user-tag"></i>
        </div>
    </div>
    
    <!-- Pending Tasks Card -->
    <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100 flex items-center justify-between">
        <div>
            <p class="text-sm font-semibold text-gray-500 uppercase tracking-wider">Pending Tasks</p>
            <h3 class="text-3xl font-bold text-rose-600 mt-1"><%= tasks.filter(t => t.status === 'Pending').length %></h3>
        </div>
        <div class="p-3 bg-rose-50 text-rose-600 rounded-lg text-xl">
            <i class="fa-solid fa-list-check"></i>
        </div>
    </div>
</div>

<!-- TWO COLUMN GRID: TASK CREATION & LIVE REMINDERS -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-8">
    
    <!-- Create New To-Do Task Form -->
    <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100 lg:col-span-2">
        <h3 class="text-lg font-bold mb-4 text-gray-800">
            <i class="fa-solid fa-circle-plus text-blue-600 mr-1"></i> Create New To-Do Task
        </h3>
        <form action="/tasks/create" method="POST" class="space-y-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Task Title</label>
                <input type="text" name="title" required placeholder="e.g., Call client for apartment viewing" class="w-full p-2.5 border rounded-lg focus:outline-blue-500">
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Due Date</label>
                    <input type="date" name="dueDate" required class="w-full p-2.5 border rounded-lg focus:outline-blue-500">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Priority</label>
                    <select name="priority" class="w-full p-2.5 border rounded-lg focus:outline-blue-500">
                        <option value="Low">Low</option>
                        <option value="Medium" selected>Medium</option>
                        <option value="High">High</option>
                    </select>
                </div>
            </div>
            <button type="submit" class="w-full bg-blue-600 text-white py-2.5 rounded-lg font-semibold hover:bg-blue-700 transition">
                Save Task
            </button>
        </form>
    </div>
    <!-- RIGHT: Live Urgent Reminders List (1 Column Width) -->
    <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100 flex flex-col justify-between">
        <div>
            <h4 class="text-lg font-bold text-gray-800 mb-4">
                <i class="fa-solid fa-bell text-amber-500 mr-1"></i> Urgent Task Reminders
            </h4>
            
            <div class="space-y-3 max-h-[290px] overflow-y-auto pr-1">
                <% const pendingTasks = tasks.filter(t => t.status === 'Pending') %>
                <% pendingTasks.forEach(task => { %>
                    <div class="flex items-start justify-between p-3 bg-slate-50 rounded-lg border-l-4 <%= task.priority === 'High' ? 'border-rose-500' : 'border-amber-500' %> shadow-sm">
                        <div class="space-y-0.5">
                            <h5 class="font-bold text-sm text-gray-900"><%= task.title %></h5>
                            <p class="text-xs text-gray-400">
                                <i class="fa-regular fa-clock"></i> Due: <%= new Date(task.dueDate).toLocaleDateString() %>
                            </p>
                        </div>
                        
                        <!-- Today Pulse Alert Indicator -->
                        <% if(new Date(task.dueDate).toDateString() === new Date().toDateString()) { %>
                            <span class="inline-flex items-center bg-rose-100 text-rose-800 text-[10px] px-2 py-0.5 rounded-full font-bold uppercase tracking-wider animate-pulse">
                                🚨 Today
                            </span>
                        <% } %>
                    </div>
                <% }) %>
                
                <% if (pendingTasks.length === 0) { %>
                    <div class="text-center py-8 text-gray-400">
                        <i class="fa-regular fa-circle-check text-2xl mb-1 text-green-400 block"></i>
                        No pending tasks!
                    </div>
                <% } %>
            </div>
        </div>
        
        <div class="text-xs text-slate-400 text-right mt-2">
            Showing all active tasks
        </div>
    </div>

</div>

<!-- TWO COLUMN GRID: ADD NEW LEAD -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-8">
    


    <!-- LEFT: Add New Lead Form -->
    <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100 lg:col-span-2">
        <h3 class="text-lg font-bold mb-4 text-gray-800">
            <i class="fa-solid fa-user-plus text-blue-600 mr-1"></i> Add New Lead
        </h3>
        <form action="/leads" method="POST" class="space-y-4">
            <!-- Basic Info Row -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Full Name</label>
                    <input type="text" name="name" required placeholder="e.g., John Doe" class="w-full p-2.5 border rounded-lg focus:outline-blue-500 text-sm">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Email Address</label>
                    <input type="email" name="email" required placeholder="e.g., john@example.com" class="w-full p-2.5 border rounded-lg focus:outline-blue-500 text-sm">
                </div>
            </div>
            
            <!-- Phone, Stage & Type Row -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Phone Number</label>
                    <input type="text" name="phone" required placeholder="e.g., +88017XXXXXXXX" class="w-full p-2.5 border rounded-lg focus:outline-blue-500 text-sm">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Lead Stage</label>
                    <select name="stage" class="w-full p-2.5 border rounded-lg focus:outline-blue-500 text-sm">
                        <option value="New Lead" selected>New Lead</option>
                        <option value="Property Viewing">Property Viewing</option>
                        <option value="Negotiation">Negotiation</option>
                        <option value="Contract Signed">Contract Signed</option>
                        <option value="Closed">Closed</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Lead Type</label>
                    <select name="leadType" required class="w-full p-2.5 border rounded-lg focus:outline-blue-500 text-sm">
                        <option value="" disabled selected>Select Type</option>
                        <option value="Buyer">Buyer</option>
                        <option value="Seller">Seller</option>
                        <option value="Tenant">Tenant</option>
                    </select>
                </div>
            </div>

            <!-- Property Interest Section (আপনার মডেলের propertyInterest অবজেক্টের জন্য) -->
            <div class="border-t border-gray-100 pt-4 mt-2">
                <h4 class="text-xs font-bold text-blue-600 uppercase tracking-wider mb-3">
                    <i class="fa-solid fa-building text-blue-500 mr-1"></i> Property Interest
                </h4>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Budget</label>
                        <input type="text" name="budget" placeholder="e.g., 80 Lacs / 1.5 Crore" class="w-full p-2.5 border rounded-lg focus:outline-blue-500 text-sm">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Preferred Location</label>
                        <input type="text" name="location" placeholder="e.g., Khilgaon, Dhaka" class="w-full p-2.5 border rounded-lg focus:outline-blue-500 text-sm">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Property Type</label>
                        <select name="propertyType" class="w-full p-2.5 border rounded-lg focus:outline-blue-500 text-sm">
                            <option value="" selected>Select Property Type</option>
                            <option value="Apartment">Apartment</option>
                            <option value="Plot">Plot</option>
                            <option value="Commercial">Commercial</option>
                        </select>
                    </div>
                </div>
            </div>

            <button type="submit" class="w-full bg-blue-600 text-white py-2.5 rounded-lg font-semibold hover:bg-blue-700 transition mt-2">
                Save Lead
            </button>
        </form>
    </div>



</div>

<%- include('partials/footer') %>