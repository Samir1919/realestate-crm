<div class="hidden lg:block min-w-0">
    <div class="w-full min-w-0 overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
        <div class="w-full min-w-0 overflow-x-hidden">
            <table class="w-full min-w-0 text-sm table-auto">
                <colgroup>
                    <col class="w-auto">
                    <col class="w-auto">
                    <col class="w-[130px]">
                    <col class="w-[140px]">
                    <col class="w-[140px]">
                    <col class="w-[100px]">
                    <col class="w-[150px]">
                    <col class="w-auto">
                    <col class="w-[130px]">
                </colgroup>
                <thead>
                    <tr class="bg-slate-50 text-slate-500 text-xs uppercase tracking-wide">
                        <th class="text-left p-3 font-semibold">Lead ID</th>
                        <th class="text-left p-3 font-semibold">Customer</th>
                        <th class="text-left p-3 font-semibold">Phone</th>
                        <th class="text-left p-3 font-semibold">Location</th>
                        <th class="text-left p-3 font-semibold">Status</th>
                        <th class="text-left p-3 font-semibold">Priority</th>
                        <th class="text-left p-3 font-semibold">Employee</th>
                        <th class="text-left p-3 font-semibold">Latest Note</th>
                        <th
                            class="text-left p-3 font-semibold sticky right-0 z-10 bg-slate-50 shadow-[-4px_0_8px_-4px_rgba(0,0,0,0.08)]">
                            Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% leads.forEach(lead=> { %>
                        <tr class="border-t border-slate-100 hover:bg-slate-50/80 transition-colors">
                            <td class="p-3 align-middle min-w-0 whitespace-nowrap">
                                <div class="min-w-0"><span class="font-mono text-[11px] text-slate-500">
                                        <%= lead.referenceNumber || lead._id %>
                                    </span>
                                </div>
                            </td>
                            <td class="p-3 align-middle min-w-0">
                                <div class="min-w-0"><span class="font-medium text-slate-900 truncate block">
                                        <%= lead.customerName || '' %>
                                    </span></div>
                            </td>
                            <td class="p-3 align-middle min-w-0">
                                <div class="min-w-0"><span class="text-slate-600 whitespace-nowrap">
                                        <%= lead.phone %>
                                    </span>
                                </div>
                            </td>
                            <td class="p-3 align-middle min-w-0">
                                <div class="min-w-0"><span class="truncate block text-slate-600">
                                        <%= lead.preferredLocation || '—' %>
                                    </span></div>
                            </td>
                            <td class="p-3 align-middle min-w-0">
                                <div class="min-w-0">
                                    <span
                                        class="inline-flex px-2 py-0.5 rounded-full text-xs border font-medium whitespace-nowrap bg-blue-100 text-blue-700 border-blue-200">
                                        <%= lead.status %>
                                    </span>
                                </div>
                            </td>
                            <td class="p-3 align-middle min-w-0">
                                <div class="min-w-0">
                                    <span
                                        class="inline-flex px-2 py-0.5 rounded-full text-xs border font-medium capitalize whitespace-nowrap bg-amber-100 text-amber-700 border-amber-200">
                                        <%= lead.priority %>
                                    </span>
                                </div>
                            </td>
                            <td class="p-3 align-middle min-w-0">
                                <div class="min-w-0"><span class="truncate block text-slate-600 text-xs">
                                        <%= lead.assignedUser && lead.assignedUser.name ? lead.assignedUser.name
                                            : 'Unassigned' %>
                                    </span>
                                </div>
                            </td>
                            <td class="p-3 align-middle min-w-0">
                                <div class="min-w-0">
                                    <span class="text-xs text-slate-500 block truncate" title="<%= lead.messageNote %>">
                                        <%= lead.messageNote || '—' %>
                                    </span>
                                </div>
                            </td>
                            <td
                                class="p-3 align-middle min-w-0 sticky right-0 z-10 bg-white shadow-[-4px_0_8px_-4px_rgba(0,0,0,0.06)]">
                                <div class="min-w-0">
                                    <div class="flex items-center gap-0.5 shrink-0">
                                        <button type="button"
                                            class="view-lead-btn inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-xl text-sm font-semibold transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 cursor-pointer hover:bg-slate-100 text-slate-700 h-8 w-8"
                                            title="View" data-lead='<%- JSON.stringify(lead) %>'
                                            onclick="openViewModalFromButton(this)">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                                                viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                                stroke-linecap="round" stroke-linejoin="round"
                                                class="lucide lucide-eye h-3.5 w-3.5" aria-hidden="true">
                                                <path
                                                    d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0">
                                                </path>
                                                <circle cx="12" cy="12" r="3"></circle>
                                            </svg>
                                        </button>
                                        <% if (canUpdateLead || (permissions && permissions.updateLead)) { %>
                                            <button type="button"
                                                class="edit-lead-btn inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-xl text-sm font-semibold transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 cursor-pointer hover:bg-slate-100 text-slate-700 h-8 w-8"
                                                title="Edit" data-id="<%= lead._id %>"
                                                data-lead='<%- JSON.stringify(lead) %>'
                                                onclick="openEditModalFromButton(this)">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                                                    viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                    stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                                                    class="lucide lucide-pencil h-3.5 w-3.5" aria-hidden="true">
                                                    <path
                                                        d="M21.174 6.812a1 1 0 0 0-3.986-3.987L3.842 16.174a2 2 0 0 0-.5.83l-1.321 4.352a.5.5 0 0 0 .623.622l4.353-1.32a2 2 0 0 0 .83-.497z">
                                                    </path>
                                                    <path d="m15 5 4 4"></path>
                                                </svg>
                                            </button>
                                            <% } %>
                                                <a href="tel:<%= lead.phone %>" title="Call">
                                                    <button
                                                        class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-xl text-sm font-semibold transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 cursor-pointer hover:bg-slate-100 text-slate-700 h-8 w-8">
                                                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                                                            viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                            stroke-width="2" stroke-linecap="round"
                                                            stroke-linejoin="round"
                                                            class="lucide lucide-phone h-3.5 w-3.5" aria-hidden="true">
                                                            <path
                                                                d="M13.832 16.568a1 1 0 0 0 1.213-.303l.355-.465A2 2 0 0 1 17 15h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2A18 18 0 0 1 2 4a2 2 0 0 1 2-2h3a2 2 0 0 1 2 2v3a2 2 0 0 1-.8 1.6l-.468.351a1 1 0 0 0-.292 1.233 14 14 0 0 0 6.392 6.384">
                                                            </path>
                                                        </svg>
                                                    </button>
                                                </a>
                                                <a href="https://wa.me/<%= lead.phone.replace(/[^0-9]/g, '') %>"
                                                    target="_blank" rel="noopener noreferrer" title="WhatsApp">
                                                    <button
                                                        class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-xl text-sm font-semibold transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 cursor-pointer hover:bg-slate-100 text-slate-700 h-8 w-8">
                                                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                                                            viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                            stroke-width="2" stroke-linecap="round"
                                                            stroke-linejoin="round"
                                                            class="lucide lucide-message-circle h-3.5 w-3.5 text-emerald-600"
                                                            aria-hidden="true">
                                                            <path
                                                                d="M2.992 16.342a2 2 0 0 1 .094 1.167l-1.065 3.29a1 1 0 0 0 1.236 1.168l3.413-.998a2 2 0 0 1 1.099.092 10 10 0 1 0-4.777-4.719">
                                                            </path>
                                                        </svg>
                                                    </button>
                                                </a>
                                                <% if (canDeleteLead || (permissions && permissions.deleteLead)) { %>
                                                    <button type="button"
                                                        class="delete-lead-btn inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-xl text-sm font-semibold transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 cursor-pointer hover:bg-slate-100 text-slate-700 h-8 w-8"
                                                        title="Delete" data-id="<%= lead._id %>"
                                                        onclick="openDeleteModalFromButton(this)">
                                                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                                                            viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                            stroke-width="2" stroke-linecap="round"
                                                            stroke-linejoin="round"
                                                            class="lucide lucide-trash-2 h-3.5 w-3.5 text-red-500"
                                                            aria-hidden="true">
                                                            <path d="M10 11v6"></path>
                                                            <path d="M14 11v6"></path>
                                                            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"></path>
                                                            <path d="M3 6h18"></path>
                                                            <path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                                                        </svg>
                                                    </button>
                                                    <% } %>
                                    </div>
                                </div>
                            </td>
                        </tr>
                        <% }) %>
                            <% if(leads.length===0) { %>
                                <tr>
                                    <td colspan="9" class="text-center py-8 text-slate-400">No leads found.</td>
                                </tr>
                                <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>