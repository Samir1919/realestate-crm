<div class="w-full min-w-0 overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm p-4">
    <div class="flex items-start justify-between gap-2 min-w-0 mb-2">
        <div class="min-w-0 flex-1">
            <h3 class="font-semibold text-slate-900 safe-truncate">
                <%= lead.customerName || '' %>
            </h3>
            <p class="text-sm text-slate-500 safe-truncate mt-0.5">
                <%= lead.phone %> · <%= lead.preferredLocation || 'No Location' %>
            </p>
        </div>
        <span
            class="inline-flex px-2 py-0.5 rounded-full text-xs border font-medium whitespace-nowrap bg-blue-100 text-blue-700 border-blue-200">
            <%= lead.status %>
        </span>
    </div>

    <div class="text-sm text-slate-600 mb-3 min-w-0">
        <div class="flex flex-wrap gap-2 items-center">
            <%- include('mobile-card-badges', { lead }) %>
        </div>
    </div>

    <div class="flex flex-wrap gap-2 pt-2 border-t border-slate-100">
        <div class="flex items-center gap-0.5 shrink-0">
            <%- include('mobile-card-actions', { lead }) %>
        </div>
    </div>
</div>