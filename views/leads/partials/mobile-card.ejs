<div
    class="flex h-full w-full min-w-0 flex-col overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm p-4 md:p-3.5">
    <div class="flex items-start justify-between gap-2 min-w-0 mb-2 md:mb-1.5">
        <div class="min-w-0 flex-1">
            <h3 class="font-semibold text-slate-900 safe-truncate text-[17px] leading-none md:text-base">
                <%= lead.customerName || '' %>
            </h3>
            <p class="text-sm text-slate-500 safe-truncate mt-0.5 md:text-[13px]">
                <%= lead.phone %> · <%= lead.preferredLocation || 'No Location' %>
            </p>
        </div>
        <div class="flex items-start gap-2">
            <span
                class="inline-flex px-2 py-0.5 rounded-full text-xs border font-medium whitespace-nowrap bg-blue-100 text-blue-700 border-blue-200 md:text-[11px]">
                <%= lead.status %>
            </span>
            <% if (canUpdateLead || (permissions && permissions.updateLead)) { %>
                <input type="checkbox"
                    class="lead-select-checkbox mt-0.5 h-4 w-4 rounded border-slate-300 text-blue-600 focus:ring-blue-500"
                    data-lead-id="<%= lead._id %>" data-lead-name="<%= lead.customerName || 'Unnamed' %>">
                <% } %>
        </div>
    </div>

    <div class="text-sm text-slate-600 mb-3 min-w-0 flex-1 md:mb-2.5 md:text-[13px]">
        <div class="flex flex-wrap gap-2 items-center">
            <%- include('mobile-card-badges', { lead }) %>
        </div>
    </div>

    <div class="flex flex-wrap gap-2 pt-2 border-t border-slate-100 md:pt-1.5 md:gap-1.5">
        <div class="flex items-center gap-0.5 shrink-0 md:gap-0">
            <%- include('mobile-card-actions', { lead }) %>
        </div>
    </div>
</div>