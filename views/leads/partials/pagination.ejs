<div class="flex flex-col sm:flex-row items-center justify-between gap-3 mt-6 min-w-0">
    <p class="text-sm text-slate-500">
        Showing
        <%= filteredTotal===0 ? 0 : (currentPage - 1) * limit + 1 %>–<%= Math.min(currentPage * limit, filteredTotal) %>
                of <%= filteredTotal %>
    </p>
    <div class="flex items-center gap-2">
        <% if (currentPage> 1) { %>
            <a href="?page=<%= currentPage - 1 %><%= preservedQuery ? '&' + preservedQuery : '' %>">
                <button
                    class="inline-flex items-center justify-center gap-2 whitespace-nowrap font-semibold transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2 cursor-pointer bg-white text-slate-700 border border-slate-200 shadow-sm hover:bg-slate-50 h-9 rounded-lg px-3 text-xs">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                        class="lucide lucide-chevron-left h-4 w-4" aria-hidden="true">
                        <path d="m15 18-6-6 6-6"></path>
                    </svg>
                </button>
            </a>
            <% } else { %>
                <button
                    class="inline-flex items-center justify-center gap-2 whitespace-nowrap font-semibold transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 bg-white text-slate-700 border border-slate-200 shadow-sm h-9 rounded-lg px-3 text-xs"
                    disabled>
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                        class="lucide lucide-chevron-left h-4 w-4" aria-hidden="true">
                        <path d="m15 18-6-6 6-6"></path>
                    </svg>
                </button>
                <% } %>

                    <span class="text-sm whitespace-nowrap">Page <%= currentPage %> of <%= totalPages || 1 %></span>

                    <% if (currentPage < totalPages) { %>
                        <a href="?page=<%= currentPage + 1 %><%= preservedQuery ? '&' + preservedQuery : '' %>">
                            <button
                                class="inline-flex items-center justify-center gap-2 whitespace-nowrap font-semibold transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2 cursor-pointer bg-white text-slate-700 border border-slate-200 shadow-sm hover:bg-slate-50 h-9 rounded-lg px-3 text-xs">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
                                    fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                    stroke-linejoin="round" class="lucide lucide-chevron-right h-4 w-4"
                                    aria-hidden="true">
                                    <path d="m9 18 6-6-6-6"></path>
                                </svg>
                            </button>
                        </a>
                        <% } else { %>
                            <button
                                class="inline-flex items-center justify-center gap-2 whitespace-nowrap font-semibold transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 bg-white text-slate-700 border border-slate-200 shadow-sm h-9 rounded-lg px-3 text-xs"
                                disabled>
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
                                    fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                    stroke-linejoin="round" class="lucide lucide-chevron-right h-4 w-4"
                                    aria-hidden="true">
                                    <path d="m9 18 6-6-6-6"></path>
                                </svg>
                            </button>
                            <% } %>
    </div>
</div>