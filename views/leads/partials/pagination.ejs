<div class="mt-6 min-w-0 rounded-2xl border border-slate-200 bg-white px-3 py-3 shadow-sm sm:px-4">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
        <p class="text-sm font-medium text-slate-600">
            Showing
            <%= filteredTotal===0 ? 0 : (currentPage - 1) * limit + 1 %>–<%= Math.min(currentPage * limit,
                    filteredTotal) %>
                    of <%= filteredTotal %>
        </p>
        <% const baseQuery=preservedQuery ? '&' + preservedQuery : '' ; const pageHref=(pageNo)=>
            `?page=${pageNo}${baseQuery}`;
            const queryEntries = Array.isArray(preservedQueryEntries) ? preservedQueryEntries : [];
            const queryEntriesWithoutPage = queryEntries.filter(([key]) => key !== 'page');
            const queryEntriesWithoutPageAndLimit = queryEntries.filter(([key]) => key !== 'page' && key !== 'limit');
            const sizes = Array.isArray(pageSizeOptions) && pageSizeOptions.length ? pageSizeOptions : [10, 25, 50];
            const pageSizeHref = (size) => {
            const params = new URLSearchParams(queryEntriesWithoutPageAndLimit);
            params.set('limit', String(size));
            params.set('page', '1');
            return `?${params.toString()}`;
            };

            const pages = [];
            const addPage = (value) => {
            pages.push(value);
            };

            const windowStart = Math.max(2, currentPage - 1);
            const windowEnd = Math.min(totalPages - 1, currentPage + 1);

            addPage(1);

            if (windowStart > 2) {
            addPage('ellipsis-left');
            }

            for (let p = windowStart; p <= windowEnd; p +=1) { addPage(p); } if (windowEnd < totalPages - 1) {
                addPage('ellipsis-right'); } if (totalPages> 1) {
                addPage(totalPages);
                }
                %>

                <div class="flex w-full flex-wrap items-center gap-2 sm:w-auto sm:justify-end">
                    <label class="text-sm text-slate-500 hidden sm:inline" for="leads-page-size">Rows</label>
                    <select id="leads-page-size"
                        class="h-10 rounded-xl border border-slate-200 bg-white px-3 text-sm text-slate-700 shadow-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500"
                        onchange="window.location.href=this.value">
                        <% sizes.forEach((size)=> { %>
                            <option value="<%= pageSizeHref(size) %>" <%=size===limit ? 'selected' : '' %>><%= size %>
                                    /page
                            </option>
                            <% }) %>
                    </select>

                    <span class="text-sm whitespace-nowrap text-slate-600 hidden sm:inline">Page <%= currentPage %> of
                            <%= totalPages %>
                    </span>

                    <% if (currentPage> 1) { %>
                        <a href="<%= pageHref(1) %>"
                            class="hidden sm:inline-flex items-center justify-center whitespace-nowrap font-semibold transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2 cursor-pointer bg-white text-slate-700 border border-slate-200 shadow-sm hover:bg-slate-50 h-10 rounded-xl px-3 text-sm">
                            First
                        </a>
                        <a href="<%= pageHref(currentPage - 1) %>"
                            class="inline-flex items-center justify-center gap-2 whitespace-nowrap font-semibold transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2 cursor-pointer bg-white text-slate-700 border border-slate-200 shadow-sm hover:bg-slate-50 h-10 rounded-xl px-3 text-sm"
                            aria-label="Previous page">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
                                fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                stroke-linejoin="round" class="lucide lucide-chevron-left h-4 w-4" aria-hidden="true">
                                <path d="m15 18-6-6 6-6"></path>
                            </svg>
                        </a>
                        <% } else { %>
                            <span
                                class="inline-flex items-center justify-center whitespace-nowrap font-semibold transition-all disabled:pointer-events-none disabled:opacity-50 bg-white text-slate-700 border border-slate-200 shadow-sm h-10 rounded-xl px-3 text-sm opacity-50 cursor-not-allowed hidden sm:inline">
                                First
                            </span>
                            <span
                                class="inline-flex items-center justify-center gap-2 whitespace-nowrap font-semibold transition-all disabled:pointer-events-none disabled:opacity-50 bg-white text-slate-700 border border-slate-200 shadow-sm h-10 rounded-xl px-3 text-sm opacity-50 cursor-not-allowed"
                                aria-hidden="true">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
                                    fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                    stroke-linejoin="round" class="lucide lucide-chevron-left h-4 w-4"
                                    aria-hidden="true">
                                    <path d="m15 18-6-6 6-6"></path>
                                </svg>
                            </span>
                            <% } %>

                                <span
                                    class="inline-flex sm:hidden items-center justify-center whitespace-nowrap font-semibold text-slate-600 h-10 rounded-xl px-3 text-sm bg-slate-50 border border-slate-200">
                                    <%= currentPage %>/<%= totalPages %>
                                </span>

                                <div class="items-center gap-1 hidden md:flex">
                                    <% pages.forEach((pageItem)=> { %>
                                        <% if (typeof pageItem==='number' ) { %>
                                            <% if (pageItem===currentPage) { %>
                                                <span
                                                    class="inline-flex items-center justify-center min-w-10 h-10 rounded-xl px-3 text-sm font-semibold bg-blue-600 text-white border border-blue-600 shadow-sm">
                                                    <%= pageItem %>
                                                </span>
                                                <% } else { %>
                                                    <a href="<%= pageHref(pageItem) %>"
                                                        class="inline-flex items-center justify-center min-w-10 h-10 rounded-xl px-3 text-sm font-semibold bg-white text-slate-700 border border-slate-200 shadow-sm hover:bg-slate-50 transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2">
                                                        <%= pageItem %>
                                                    </a>
                                                    <% } %>
                                                        <% } else { %>
                                                            <span
                                                                class="inline-flex items-center justify-center min-w-9 h-9 px-2 text-sm text-slate-400">…</span>
                                                            <% } %>
                                                                <% }) %>
                                </div>

                                <form method="get" class="hidden lg:flex items-center gap-2 ml-1">
                                    <% queryEntriesWithoutPage.forEach(([key, value])=> { %>
                                        <input type="hidden" name="<%= key %>" value="<%= value %>">
                                        <% }) %>
                                            <label for="jump-page" class="text-xs text-slate-500">Go to</label>
                                            <input id="jump-page" type="number" name="page" min="1"
                                                max="<%= totalPages %>" value="<%= currentPage %>"
                                                class="h-10 w-16 rounded-xl border border-slate-200 px-2 text-sm text-slate-700 shadow-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500">
                                            <button type="submit"
                                                class="inline-flex items-center justify-center whitespace-nowrap font-semibold transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2 cursor-pointer bg-white text-slate-700 border border-slate-200 shadow-sm hover:bg-slate-50 h-10 rounded-xl px-3 text-sm">
                                                Go
                                            </button>
                                </form>

                                <% if (currentPage < totalPages) { %>
                                    <a href="<%= pageHref(currentPage + 1) %>"
                                        class="inline-flex items-center justify-center gap-2 whitespace-nowrap font-semibold transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2 cursor-pointer bg-white text-slate-700 border border-slate-200 shadow-sm hover:bg-slate-50 h-10 rounded-xl px-3 text-sm"
                                        aria-label="Next page">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                                            viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                            stroke-linecap="round" stroke-linejoin="round"
                                            class="lucide lucide-chevron-right h-4 w-4" aria-hidden="true">
                                            <path d="m9 18 6-6-6-6"></path>
                                        </svg>
                                    </a>
                                    <a href="<%= pageHref(totalPages) %>"
                                        class="hidden sm:inline-flex items-center justify-center whitespace-nowrap font-semibold transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2 cursor-pointer bg-white text-slate-700 border border-slate-200 shadow-sm hover:bg-slate-50 h-10 rounded-xl px-3 text-sm">
                                        Last
                                    </a>
                                    <% } else { %>
                                        <span
                                            class="inline-flex items-center justify-center gap-2 whitespace-nowrap font-semibold transition-all disabled:pointer-events-none disabled:opacity-50 bg-white text-slate-700 border border-slate-200 shadow-sm h-10 rounded-xl px-3 text-sm opacity-50 cursor-not-allowed"
                                            aria-hidden="true">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                                                viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                                stroke-linecap="round" stroke-linejoin="round"
                                                class="lucide lucide-chevron-right h-4 w-4" aria-hidden="true">
                                                <path d="m9 18 6-6-6-6"></path>
                                            </svg>
                                        </span>
                                        <span
                                            class="inline-flex items-center justify-center whitespace-nowrap font-semibold transition-all disabled:pointer-events-none disabled:opacity-50 bg-white text-slate-700 border border-slate-200 shadow-sm h-10 rounded-xl px-3 text-sm opacity-50 cursor-not-allowed hidden sm:inline">
                                            Last
                                        </span>
                                        <% } %>
                </div>
    </div>
</div>