<div class="lg:hidden min-w-0">
    <div class="mb-3 flex items-center justify-between gap-2">
        <h2 class="text-sm font-semibold tracking-wide text-slate-700">Leads List</h2>
        <span class="text-xs text-slate-500">Card View</span>
    </div>
    <div class="mb-3 h-px w-full bg-slate-200"></div>

    <div class="space-y-3 min-w-0">
        <% leads.forEach((lead)=> { %>
            <%- include('mobile-card', { lead }) %>
                <% }); %>

                    <% if (leads.length===0) { %>
                        <div
                            class="text-center py-8 text-slate-400 bg-white border border-slate-200 rounded-2xl shadow-sm">
                            No leads found.
                        </div>
                        <% } %>
    </div>
</div>