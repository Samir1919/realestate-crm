function showPopupMessage(message, type = 'error', options = {}) {
const { duration = 3200, actions = [] } = options;
const existingPopup = document.getElementById('leadFormPopupMessage');
if (existingPopup) {
existingPopup.remove();
}

const popup = document.createElement('div');
popup.id = 'leadFormPopupMessage';
popup.className = [
'fixed top-5 right-5 z-[80] rounded-lg shadow-lg px-4 py-3 text-sm font-medium max-w-sm space-y-2',
type === 'success'
? 'bg-green-50 text-green-800 border border-green-200'
: 'bg-red-50 text-red-800 border border-red-200'
].join(' ');

const messageNode = document.createElement('p');
messageNode.textContent = message || 'Something went wrong. Please try again.';
popup.appendChild(messageNode);

if (actions.length) {
const actionWrap = document.createElement('div');
actionWrap.className = 'flex items-center gap-2';

actions.forEach((action) => {
const actionButton = document.createElement('button');
actionButton.type = 'button';
actionButton.textContent = action.label;
actionButton.className = action.className || 'toast-action-btn';
actionButton.addEventListener('click', () => {
popup.remove();
if (typeof action.onClick === 'function') {
action.onClick();
}
});
actionWrap.appendChild(actionButton);
});

popup.appendChild(actionWrap);
}

document.body.appendChild(popup);
setTimeout(() => {
popup.remove();
}, duration);
}

async function submitLeadFormAjax(form, options = {}) {
const submitButton = form.querySelector('button[type="submit"]');
const previousLabel = submitButton ? submitButton.textContent : '';
const shouldShowSuccessMessage = options.showSuccessMessage !== false;

if (submitButton) {
submitButton.disabled = true;
submitButton.textContent = 'Saving...';
}

try {
const formPayload = new URLSearchParams(new FormData(form));

const response = await fetch(form.action, {
method: 'POST',
headers: {
'Accept': 'application/json',
'X-Requested-With': 'XMLHttpRequest'
},
body: formPayload
});

const payload = await response.json().catch(() => null);
const message = payload && payload.message
? payload.message
: (response.ok ? 'Saved successfully.' : 'Request failed.');

if (!response.ok) {
showPopupMessage(message, 'error');
return false;
}

if (options.resetForm) {
form.reset();
}

if (typeof options.onSuccess === 'function') {
options.onSuccess(message);
}

if (shouldShowSuccessMessage) {
showPopupMessage(message, 'success');
}
return true;
} catch (error) {
showPopupMessage('Server connection failed. Please try again.', 'error');
return false;
} finally {
if (submitButton) {
submitButton.disabled = false;
submitButton.textContent = previousLabel;
}
}
}

if (addLeadForm) {
addLeadForm.addEventListener('input', saveLeadFormDraft);
addLeadForm.addEventListener('change', saveLeadFormDraft);

if (addPhoneInput) {
addPhoneInput.addEventListener('input', () => validateAddPhoneInline(true));
addPhoneInput.addEventListener('blur', () => validateAddPhoneInline(false));
}

addLeadForm.addEventListener('submit', async (event) => {
event.preventDefault();
if (!validateAddPhoneInline(false)) {
addPhoneInput.focus();
return;
}

const ok = await submitLeadFormAjax(addLeadForm, {
resetForm: true,
showSuccessMessage: false,
onSuccess: (successMessage) => {
clearLeadFormDraft();
closeModal();

let shouldRefresh = true;
const refreshTimer = setTimeout(async () => {
if (shouldRefresh) {
await softRefreshLeadSections();
}
}, 1200);

showPopupMessage(successMessage, 'success', {
duration: 5000,
actions: [
{
label: 'Add another',
onClick: () => {
shouldRefresh = false;
clearTimeout(refreshTimer);
openModal();
}
},
{
label: 'Refresh list',
onClick: async () => {
shouldRefresh = false;
clearTimeout(refreshTimer);
await softRefreshLeadSections();
}
}
]
});
}
});

if (!ok) {
openModal();
}
});
}

if (editLeadForm) {
editLeadForm.addEventListener('submit', async (event) => {
event.preventDefault();
if (editPhoneInput) {
editPhoneInput.value = sanitizePhoneInputValue(editPhoneInput.value);
if (!isValidPhoneInputValue(editPhoneInput.value)) {
showPopupMessage(phoneValidationMessage, 'error');
editPhoneInput.focus();
return;
}
}

await submitLeadFormAjax(editLeadForm, {
onSuccess: async () => {
closeEditModal();
await softRefreshLeadSections();
}
});
});
}

function bindModalActionForm(form, closeModalFn) {
if (!form) {
return;
}

form.addEventListener('submit', async (event) => {
event.preventDefault();
await submitLeadFormAjax(form, {
onSuccess: async () => {
if (typeof closeModalFn === 'function') {
closeModalFn();
}
await softRefreshLeadSections();
}
});
});
}

bindModalActionForm(deleteLeadForm, closeDeleteModal);
bindModalActionForm(requestLeadInactiveForm, closeRequestInactiveModal);
bindModalActionForm(restoreLeadForm, closeRestoreModal);
bindModalActionForm(rejectLeadRequestForm, closeRejectLeadRequestModal);