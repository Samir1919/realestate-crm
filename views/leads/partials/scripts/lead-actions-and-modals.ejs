document.addEventListener('keydown', (event) => {
if (event.key !== 'Escape') {
return;
}

if (leadModal && !leadModal.classList.contains('hidden')) {
closeModal();
}
});

window.onclick = function (event) {
const editModal = document.getElementById('editLeadModal');
const deleteModal = document.getElementById('deleteLeadModal');
const requestInactiveModal = document.getElementById('requestLeadInactiveModal');
const restoreModal = document.getElementById('restoreLeadModal');
const rejectLeadRequestModal = document.getElementById('rejectLeadRequestModal');
const viewModal = document.getElementById('viewLeadModal');

if (event.target == editModal) {
closeEditModal();
}
if (event.target == deleteModal) {
closeDeleteModal();
}
if (event.target == requestInactiveModal) {
closeRequestInactiveModal();
}
if (event.target == restoreModal) {
closeRestoreModal();
}
if (event.target == rejectLeadRequestModal) {
closeRejectLeadRequestModal();
}
if (event.target == viewModal) {
closeViewModal();
}
};

