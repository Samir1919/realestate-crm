function openEditModalFromButton(button) {
const leadAttr = button.getAttribute('data-lead');
if (!leadAttr) return;
try {
const lead = JSON.parse(leadAttr);
openEditModal(lead);
} catch (err) {
console.error('Failed to parse lead data', err);
}
}

function openDeleteModalFromButton(button) {
const leadAttr = button.getAttribute('data-lead');
if (leadAttr) {
try {
openDeleteModal(JSON.parse(leadAttr));
return;
} catch (err) {
console.error('Failed to parse lead data', err);
}
}

const leadId = button.getAttribute('data-id');
if (leadId) {
openDeleteModal({ _id: leadId });
}
}

function openRequestInactiveModalFromButton(button) {
const leadAttr = button.getAttribute('data-lead');
if (!leadAttr) return;
try {
openRequestInactiveModal(JSON.parse(leadAttr));
} catch (err) {
console.error('Failed to parse lead data', err);
}
}

function openRestoreModalFromButton(button) {
