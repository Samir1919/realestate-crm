async function openRequestInactiveModalFromEditButton(button) {
const leadAttr = button.getAttribute('data-lead');
if (!leadAttr) return;
try {
const lead = JSON.parse(leadAttr);
const editForm = document.getElementById('editLeadForm');

if (editForm && typeof submitLeadFormAjax === 'function') {
editForm.action = editForm.action || `/leads/update/${lead._id}`;
const saved = await submitLeadFormAjax(editForm, { showSuccessMessage: false });
if (!saved) {
showPopupMessage('Save failed. ঠিক করে ঠিক করে আবার চেষ্টা করুন।', 'error');
return;
}

// Build updated lead object from form fields
const updatedLead = Object.assign({}, lead, {
customerName: document.getElementById('edit_customerName')?.value || lead.customerName,
phone: document.getElementById('edit_phone')?.value || lead.phone,
preferredLocation: document.getElementById('edit_preferredLocation')?.value || lead.preferredLocation,
propertyType: document.getElementById('edit_propertyType')?.value || lead.propertyType,
budgetMin: document.getElementById('edit_budgetMin')?.value || lead.budgetMin,
budgetMax: document.getElementById('edit_budgetMax')?.value || lead.budgetMax,
preferredSize: document.getElementById('edit_preferredSize')?.value || lead.preferredSize,
bedrooms: document.getElementById('edit_bedrooms')?.value || lead.bedrooms,
purpose: document.getElementById('edit_purpose')?.value || lead.purpose,
source: document.getElementById('edit_source')?.value || lead.source,
assignedUser: document.getElementById('edit_assignedUser')?.value || (lead.assignedUser && (lead.assignedUser._id ||
lead.assignedUser)),
priority: document.getElementById('edit_priority')?.value || lead.priority,
leadType: document.getElementById('edit_leadType')?.value || lead.leadType,
status: document.getElementById('edit_status')?.value || lead.status,
isActive: (document.getElementById('edit_isActive')?.value === 'false') ? false : true,
messageNote: document.getElementById('edit_messageNote')?.value || lead.messageNote,
followUpDate: document.getElementById('edit_followUpDate')?.value || lead.followUpDate
});

closeEditModal();
openRequestInactiveModal(updatedLead);
return;
}

// Fallback
hideEditModalForFollowUpAction();
openRequestInactiveModal(lead);
} catch (err) {
console.error('Failed to parse lead data', err);
}
}

function hideEditModalForFollowUpAction() {
const modal = document.getElementById('editLeadModal');
const modalPanel = modal ? modal.children[0] : null;
if (!modal || !modalPanel) return;
modalPanel.classList.add('scale-95');
modal.classList.add('hidden');
modal.style.display = 'none';
}

window.openEditModalFromButton = openEditModalFromButton;
window.openDeleteModalFromButton = openDeleteModalFromButton;
window.openRequestInactiveModalFromButton = openRequestInactiveModalFromButton;
window.openRestoreModalFromButton = openRestoreModalFromButton;
window.openRejectLeadRequestModalFromButton = openRejectLeadRequestModalFromButton;
window.openViewModalFromButton = openViewModalFromButton;

document.addEventListener('click', (event) => {
const editButton = event.target.closest('.edit-lead-btn');
if (editButton) {
event.preventDefault();
event.stopPropagation();
openEditModalFromButton(editButton);
return;
}

const deleteButton = event.target.closest('.delete-lead-btn');
if (deleteButton) {
event.preventDefault();
event.stopPropagation();
openDeleteModalFromButton(deleteButton);
return;
}

const requestInactiveButton = event.target.closest('.inactive-request-btn');
if (requestInactiveButton) {
event.preventDefault();
event.stopPropagation();
openRequestInactiveModalFromButton(requestInactiveButton);
return;
}

const editRequestInactiveButton = event.target.closest('#edit_requestInactiveBtn');
if (editRequestInactiveButton) {
event.preventDefault();
event.stopPropagation();
openRequestInactiveModalFromEditButton(editRequestInactiveButton);
return;
}

const restoreButton = event.target.closest('.restore-lead-btn');
if (restoreButton) {
event.preventDefault();
event.stopPropagation();
openRestoreModalFromButton(restoreButton);
return;
}

const rejectButton = event.target.closest('.reject-inactive-request-btn');
if (rejectButton) {
event.preventDefault();
event.stopPropagation();
openRejectLeadRequestModalFromButton(rejectButton);
return;
}

const viewButton = event.target.closest('.view-lead-btn');
if (viewButton) {
event.preventDefault();
event.stopPropagation();
openViewModalFromButton(viewButton);
}
});

function openEditModal(lead) {
const modal = document.getElementById('editLeadModal');
const form = document.getElementById('editLeadForm');
const modalPanel = modal ? modal.children[0] : null;

if (!modal || !form || !modalPanel) return;

form.action = `/leads/update/${lead._id}`;

document.getElementById('edit_customerName').value = lead.customerName || '';
document.getElementById('edit_phone').value = sanitizePhoneInputValue(lead.phone || '');
document.getElementById('edit_preferredLocation').value = lead.preferredLocation || '';
document.getElementById('edit_propertyType').value = lead.propertyType || '';
document.getElementById('edit_budgetMin').value = lead.budgetMin || '';
document.getElementById('edit_budgetMax').value = lead.budgetMax || '';
document.getElementById('edit_preferredSize').value = lead.preferredSize || '';
document.getElementById('edit_bedrooms').value = lead.bedrooms || '';
document.getElementById('edit_purpose').value = lead.purpose || '';
document.getElementById('edit_source').value = lead.source || '';
document.getElementById('edit_assignedUser').value = (lead.assignedUser && (lead.assignedUser._id || lead.assignedUser))
|| '';
document.getElementById('edit_priority').value = lead.priority || '';
document.getElementById('edit_leadType').value = lead.leadType || 'good';
document.getElementById('edit_status').value = lead.status || 'new';
document.getElementById('edit_isActive').value = lead.isActive === false ? 'false' : 'true';
document.getElementById('edit_messageNote').value = lead.messageNote || '';
updateEditInactiveRequestAction(lead);

if (lead.followUpDate) {
const date = new Date(lead.followUpDate);
const formattedDate = date.toISOString().split('T')[0];
document.getElementById('edit_followUpDate').value = formattedDate;
} else {
document.getElementById('edit_followUpDate').value = '';
}

modal.classList.remove('hidden');
modal.style.display = 'flex';
modalPanel.classList.remove('scale-95');
lockBodyScroll();
}

function updateEditInactiveRequestAction(lead) {
const action = document.getElementById('edit_inactiveRequestAction');
const requestButton = document.getElementById('edit_requestInactiveBtn');
const pendingBadge = document.getElementById('edit_inactiveRequestPending');
if (!action || !requestButton || !pendingBadge) return;

const isInactive = lead.isActive === false;
const hasPendingRequest = lead.inactiveRequest && lead.inactiveRequest.status === 'pending';

action.classList.toggle('hidden', isInactive);
requestButton.classList.toggle('hidden', hasPendingRequest || isInactive);
pendingBadge.classList.toggle('hidden', !hasPendingRequest || isInactive);
requestButton.setAttribute('data-lead', JSON.stringify(lead));
}

function closeEditModal() {
const modal = document.getElementById('editLeadModal');
const modalPanel = modal ? modal.children[0] : null;
if (!modal || !modalPanel) return;
modalPanel.classList.add('scale-95');
setTimeout(() => {
modal.classList.add('hidden');
modal.style.display = 'none';
unlockBodyScroll();
}, 150);
}

function openDeleteModal(lead) {
const modal = document.getElementById('deleteLeadModal');
const form = document.getElementById('deleteLeadForm');
const modalPanel = modal ? modal.children[0] : null;
const title = document.getElementById('deleteLeadModalTitle');
const description = document.getElementById('deleteLeadModalDescription');
const submitButton = document.getElementById('deleteLeadSubmitBtn');
const reviewNote = document.getElementById('deleteLeadReviewNote');

if (!modal || !form || !modalPanel || !lead || !lead._id) return;

form.action = `/leads/delete/${lead._id}`;

const hasPendingRequest = lead.inactiveRequest && lead.inactiveRequest.status === 'pending';
const requester = hasPendingRequest ? (lead.inactiveRequest.requestedByName || 'A sales user') : '';
const requestNote = hasPendingRequest && lead.inactiveRequest.note ? ` Reason: ${lead.inactiveRequest.note}` : '';

if (hasPendingRequest) {
title.textContent = 'Approve Inactive Request';
description.textContent = `${requester} requested admin approval to mark this lead inactive.${requestNote}`;
submitButton.textContent = 'Approve & Inactive';
submitButton.className = [
'bg-amber-600 hover:bg-amber-700 text-white',
'px-5 py-2 rounded-lg text-sm font-medium shadow transition'
].join(' ');
reviewNote.classList.remove('hidden');
} else {
title.textContent = 'Archive Lead';
description.textContent = 'This will mark the lead as inactive and hide it from the default active list. '
+ 'You can still find it later from the inactive filter.';
submitButton.textContent = 'Archive';
submitButton.className = [
'bg-amber-600 hover:bg-amber-700 text-white',
'px-5 py-2 rounded-lg text-sm font-medium shadow transition'
].join(' ');
reviewNote.classList.add('hidden');
reviewNote.value = '';
}

modal.classList.remove('hidden');
modal.style.display = 'flex';
modalPanel.classList.remove('scale-95');
lockBodyScroll();
}

function closeDeleteModal() {
const modal = document.getElementById('deleteLeadModal');
const modalPanel = modal ? modal.children[0] : null;
if (!modal || !modalPanel) return;
modalPanel.classList.add('scale-95');
setTimeout(() => {
modal.classList.add('hidden');
modal.style.display = 'none';
unlockBodyScroll();
}, 150);
}

