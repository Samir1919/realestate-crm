<script>
    const openModalBtn = document.getElementById('openModalBtn');
    const closeModalBtn = document.getElementById('closeModalBtn');
    const cancelModalBtn = document.getElementById('cancelModalBtn');
    const leadModal = document.getElementById('leadModal');
    const leadModalPanel = document.getElementById('leadModalPanel');
    const mobileStatsToggleBtn = document.getElementById('mobileStatsToggleBtn');
    const mobileStatsToggleLabel = document.getElementById('mobileStatsToggleLabel');
    const mobileStatsPanel = document.getElementById('mobileStatsPanel');
    const mobileFiltersToggleBtn = document.getElementById('mobileFiltersToggleBtn');
    const mobileFiltersToggleLabel = document.getElementById('mobileFiltersToggleLabel');
    const mobileFiltersPanel = document.getElementById('mobileFiltersPanel');
    const leadsVersionStateElement = document.getElementById('leadsVersionState');
    const realtimePollIntervalSelect = document.getElementById('realtimePollInterval');
    const realtimePollWarning = document.getElementById('realtimePollWarning');
    const leadDraftNotice = document.getElementById('leadDraftNotice');
    const clearDraftBtn = document.getElementById('clearDraftBtn');

    const importLeadsBtn = document.getElementById('importLeadsBtn');
    const importCsvInput = document.getElementById('importCsvInput');
    const addLeadForm = document.getElementById('addLeadForm');
    const editLeadForm = document.getElementById('editLeadForm');
    const deleteLeadForm = document.getElementById('deleteLeadForm');
    const requestLeadInactiveForm = document.getElementById('requestLeadInactiveForm');
    const restoreLeadForm = document.getElementById('restoreLeadForm');
    const rejectLeadRequestForm = document.getElementById('rejectLeadRequestForm');
    const bulkAssignPanel = document.getElementById('bulkAssignPanel');
    const bulkAssignUser = document.getElementById('bulkAssignUser');
    const bulkAssignBtn = document.getElementById('bulkAssignBtn');
    const bulkClearSelectionBtn = document.getElementById('bulkClearSelectionBtn');
    const bulkClearPageSelectionBtn = document.getElementById('bulkClearPageSelectionBtn');
    const bulkSelectedCount = document.getElementById('bulkSelectedCount');
    const bulkAssignConfirmModal = document.getElementById('bulkAssignConfirmModal');
    const bulkAssignConfirmSummary = document.getElementById('bulkAssignConfirmSummary');
    const bulkAssignConfirmAssignee = document.getElementById('bulkAssignConfirmAssignee');
    const bulkAssignPreviewList = document.getElementById('bulkAssignPreviewList');
    const bulkAssignPreviewMeta = document.getElementById('bulkAssignPreviewMeta');
    const confirmBulkAssignBtn = document.getElementById('confirmBulkAssignBtn');
    const cancelBulkAssignConfirmBtn = document.getElementById('cancelBulkAssignConfirmBtn');
    const closeBulkAssignConfirmModalBtn = document.getElementById('closeBulkAssignConfirmModalBtn');
    const addPhoneInput = document.getElementById('lead_phone');
    const editPhoneInput = document.getElementById('edit_phone');
    const addPhoneInlineError = document.getElementById('addPhoneInlineError');
    const phoneValidationMessage = 'সঠিক ফোন নম্বর দিন। দেশ কোডসহ valid number দিন, যেমন +880..., +1..., বা local BD mobile।';
    const leadDraftStorageKey = 'lead-form-draft-v1';
    const bulkSelectionStorageKey = 'lead-bulk-selection-v1';
    const realtimePollStorageKey = 'lead-realtime-poll-ms-v1';
    const allowedRealtimePollIntervals = [2000, 5000, 10000, 15000, 30000];
    const selectedLeadIds = new Set();

    let bodyScrollLocks = 0;
    let leadModalCloseTimer = null;
    let leadsRealtimePollMs = 10000;
    let realtimePollTimer = null;
    let currentLeadsVersion = leadsVersionStateElement ? String(leadsVersionStateElement.value || '') : '';

    function getSavedRealtimePollMs() {
        const raw = localStorage.getItem(realtimePollStorageKey);
        const parsed = Number.parseInt(raw || '', 10);

        if (allowedRealtimePollIntervals.includes(parsed)) {
            return parsed;
        }

        return 10000;
    }

    function applyRealtimePollSelection(nextMs) {
        const normalizedMs = allowedRealtimePollIntervals.includes(nextMs) ? nextMs : 10000;
        leadsRealtimePollMs = normalizedMs;
        localStorage.setItem(realtimePollStorageKey, String(normalizedMs));

        if (realtimePollIntervalSelect) {
            realtimePollIntervalSelect.value = String(normalizedMs);
        }

        if (realtimePollWarning) {
            realtimePollWarning.classList.toggle('hidden', normalizedMs !== 2000);
        }
    }

    function startRealtimePolling() {
        if (realtimePollTimer) {
            clearInterval(realtimePollTimer);
        }

        realtimePollTimer = setInterval(async () => {
            if (document.hidden || hasOpenModal()) {
                return;
            }

            const nextVersion = await fetchLatestLeadsVersion();
            if (!nextVersion || nextVersion === currentLeadsVersion) {
                return;
            }

            const refreshed = await softRefreshLeadSections();
            if (!refreshed) {
                currentLeadsVersion = nextVersion;
                if (leadsVersionStateElement) {
                    leadsVersionStateElement.value = nextVersion;
                }
            }
        }, leadsRealtimePollMs);
    }

    function getLeadsVersionCheckUrl() {
        const currentUrl = new URL(window.location.href);
        const versionUrl = new URL('/api/leads/version', window.location.origin);

        currentUrl.searchParams.forEach((value, key) => {
            versionUrl.searchParams.append(key, value);
        });

        return versionUrl.toString();
    }

    async function fetchLatestLeadsVersion() {
        try {
            const response = await fetch(getLeadsVersionCheckUrl(), {
                method: 'GET',
                headers: {
                    'Accept': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                }
            });

            if (!response.ok) {
                return null;
            }

            const payload = await response.json();
            if (!payload || payload.success !== true || !payload.version) {
                return null;
            }

            return String(payload.version);
        } catch (error) {
            return null;
        }
    }

    applyRealtimePollSelection(getSavedRealtimePollMs());

    if (realtimePollIntervalSelect) {
        realtimePollIntervalSelect.addEventListener('change', () => {
            const selectedMs = Number.parseInt(realtimePollIntervalSelect.value || '', 10);
            applyRealtimePollSelection(selectedMs);
            startRealtimePolling();
        });
    }

    function updateMobileStatsToggleState() {
        if (!mobileStatsToggleBtn || !mobileStatsPanel) {
            return;
        }

        const isOpen = !mobileStatsPanel.classList.contains('hidden');
        mobileStatsToggleBtn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');

        if (mobileStatsToggleLabel) {
            mobileStatsToggleLabel.textContent = isOpen ? 'Hide Stats' : 'Show Stats';
        }
    }

    if (mobileStatsToggleBtn && mobileStatsPanel) {
        updateMobileStatsToggleState();

        mobileStatsToggleBtn.addEventListener('click', () => {
            mobileStatsPanel.classList.toggle('hidden');
            updateMobileStatsToggleState();
        });
    }

    function updateMobileFiltersToggleState() {
        if (!mobileFiltersToggleBtn || !mobileFiltersPanel) {
            return;
        }

        const isOpen = !mobileFiltersPanel.classList.contains('hidden');
        mobileFiltersToggleBtn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');

        if (mobileFiltersToggleLabel) {
            mobileFiltersToggleLabel.textContent = isOpen ? 'Hide Filters' : 'Show Filters';
        }
    }

    if (mobileFiltersToggleBtn && mobileFiltersPanel) {
        updateMobileFiltersToggleState();

        mobileFiltersToggleBtn.addEventListener('click', () => {
            mobileFiltersPanel.classList.toggle('hidden');
            updateMobileFiltersToggleState();
        });
    }

    function lockBodyScroll() {
        bodyScrollLocks += 1;
        if (bodyScrollLocks > 1) {
            return;
        }

        const scrollbarWidth = window.innerWidth - document.documentElement.clientWidth;
        document.body.dataset.prevOverflow = document.body.style.overflow || '';
        document.body.dataset.prevPaddingRight = document.body.style.paddingRight || '';
        document.body.style.overflow = 'hidden';

        if (scrollbarWidth > 0) {
            document.body.style.paddingRight = `${scrollbarWidth}px`;
        }
    }

    function unlockBodyScroll() {
        bodyScrollLocks = Math.max(0, bodyScrollLocks - 1);
        if (bodyScrollLocks !== 0) {
            return;
        }

        document.body.style.overflow = document.body.dataset.prevOverflow || '';
        document.body.style.paddingRight = document.body.dataset.prevPaddingRight || '';
        delete document.body.dataset.prevOverflow;
        delete document.body.dataset.prevPaddingRight;
    }

    function closeModal() {
        if (!leadModal) {
            return;
        }

        if (leadModalPanel) {
            leadModalPanel.classList.add('scale-95');
        }

        if (leadModalCloseTimer) {
            clearTimeout(leadModalCloseTimer);
        }

        leadModalCloseTimer = setTimeout(() => {
            leadModal.classList.add('hidden');
            leadModal.classList.remove('flex');
            leadModalCloseTimer = null;
        }, 140);

        clearAddPhoneInlineError();
        unlockBodyScroll();
    }

    function openModal() {
        if (!leadModal) {
            return;
        }

        if (leadModalCloseTimer) {
            clearTimeout(leadModalCloseTimer);
            leadModalCloseTimer = null;
        }

        leadModal.classList.remove('hidden');
        leadModal.classList.add('flex');

        if (leadModalPanel) {
            leadModalPanel.classList.remove('scale-95');
        }

        lockBodyScroll();
        restoreLeadFormDraft();
        validateAddPhoneInline(true);
    }

    if (openModalBtn) openModalBtn.addEventListener('click', openModal);
    if (closeModalBtn) closeModalBtn.addEventListener('click', closeModal);
    if (cancelModalBtn) cancelModalBtn.addEventListener('click', closeModal);
    if (clearDraftBtn) clearDraftBtn.addEventListener('click', clearLeadFormDraft);

    if (leadModal) {
        leadModal.addEventListener('click', (e) => {
            if (e.target === leadModal) {
                closeModal();
            }
        });
    }

    function showDraftNotice(show) {
        if (!leadDraftNotice) {
            return;
        }

        leadDraftNotice.classList.toggle('hidden', !show);
    }

    function saveLeadFormDraft() {
        if (!addLeadForm) {
            return;
        }

        const payload = {};
        const formData = new FormData(addLeadForm);
        for (const [name, value] of formData.entries()) {
            payload[name] = String(value || '');
        }

        localStorage.setItem(leadDraftStorageKey, JSON.stringify(payload));
    }

    function clearLeadFormDraft() {
        localStorage.removeItem(leadDraftStorageKey);
        showDraftNotice(false);
    }

    function restoreLeadFormDraft() {
        if (!addLeadForm) {
            return;
        }

        const rawDraft = localStorage.getItem(leadDraftStorageKey);
        if (!rawDraft) {
            showDraftNotice(false);
            return;
        }

        try {
            const draft = JSON.parse(rawDraft);
            let restoredAnyValue = false;

            Object.entries(draft).forEach(([name, value]) => {
                const field = addLeadForm.elements.namedItem(name);
                if (!field || typeof field.value === 'undefined') {
                    return;
                }

                if (String(value || '').trim()) {
                    restoredAnyValue = true;
                }

                field.value = value;
            });

            showDraftNotice(restoredAnyValue);
        } catch (error) {
            localStorage.removeItem(leadDraftStorageKey);
            showDraftNotice(false);
        }
    }

    function clearAddPhoneInlineError() {
        if (addPhoneInlineError) {
            addPhoneInlineError.textContent = '';
        }

        if (addPhoneInput) {
            addPhoneInput.classList.remove('border-red-400', 'ring-red-200');
        }
    }

    function setAddPhoneInlineError(message) {
        if (!addPhoneInput) {
            return;
        }

        if (addPhoneInlineError) {
            addPhoneInlineError.textContent = message || '';
        }

        if (message) {
            addPhoneInput.classList.add('border-red-400');
            return;
        }

        addPhoneInput.classList.remove('border-red-400');
    }

    function sanitizePhoneInputValue(value) {
        const rawValue = String(value || '').trim();
        if (!rawValue) {
            return '';
        }

        const compactValue = rawValue.replace(/[\s().-]/g, '');
        const normalizedPlusPrefix = compactValue.startsWith('00') ? `+${compactValue.slice(2)}` : compactValue;

        if (normalizedPlusPrefix.startsWith('+')) {
            return `+${normalizedPlusPrefix.slice(1).replace(/\D/g, '')}`;
        }

        return normalizedPlusPrefix.replace(/\D/g, '');
    }

    function isValidPhoneInputValue(value) {
        return /^(\+\d{8,15}|\d{8,15})$/.test(sanitizePhoneInputValue(value));
    }

    function bindPhoneSanitizer(input) {
        if (!input) {
            return;
        }

        const applySanitizedValue = () => {
            input.value = sanitizePhoneInputValue(input.value);
        };

        input.addEventListener('input', applySanitizedValue);
        input.addEventListener('blur', applySanitizedValue);
        applySanitizedValue();
    }

    bindPhoneSanitizer(addPhoneInput);
    bindPhoneSanitizer(editPhoneInput);

    function validateAddPhoneInline(skipRequiredCheck = false) {
        if (!addPhoneInput) {
            return true;
        }

        const sanitizedValue = sanitizePhoneInputValue(addPhoneInput.value);
        addPhoneInput.value = sanitizedValue;

        if (!sanitizedValue && !skipRequiredCheck) {
            setAddPhoneInlineError('ফোন নম্বর দেয়া বাধ্যতামূলক।');
            return false;
        }

        if (sanitizedValue && !isValidPhoneInputValue(sanitizedValue)) {
            setAddPhoneInlineError(phoneValidationMessage);
            return false;
        }

        clearAddPhoneInlineError();
        return true;
    }

    function setupFormKeyboardFlow(form) {
        if (!form) {
            return;
        }

        const fields = Array.from(form.querySelectorAll('input, select, textarea')).filter((element) => {
            if (!element || element.disabled) {
                return false;
            }
            return element.type !== 'hidden';
        });

        fields.forEach((field, index) => {
            field.addEventListener('keydown', (event) => {
                if (event.key !== 'Enter' || field.tagName.toLowerCase() === 'textarea') {
                    return;
                }

                event.preventDefault();
                const nextField = fields[index + 1];
                if (nextField) {
                    nextField.focus();
                } else {
                    const submitButton = form.querySelector('button[type="submit"]');
                    if (submitButton) {
                        submitButton.focus();
                    }
                }
            });
        });
    }

    setupFormKeyboardFlow(addLeadForm);

    function restoreBulkSelectionFromStorage() {
        const raw = sessionStorage.getItem(bulkSelectionStorageKey);
        if (!raw) {
            return;
        }

        try {
            const storedIds = JSON.parse(raw);
            if (!Array.isArray(storedIds)) {
                return;
            }

            storedIds.forEach((id) => {
                const normalized = String(id || '').trim();
                if (normalized) {
                    selectedLeadIds.add(normalized);
                }
            });
        } catch (error) {
            sessionStorage.removeItem(bulkSelectionStorageKey);
        }
    }

    function persistBulkSelection() {
        sessionStorage.setItem(bulkSelectionStorageKey, JSON.stringify(Array.from(selectedLeadIds)));
    }

    function getLeadSelectionCheckboxes() {
        return Array.from(document.querySelectorAll('.lead-select-checkbox'));
    }

    function getVisibleLeadIds() {
        return new Set(getLeadSelectionCheckboxes().map((checkbox) => checkbox.dataset.leadId).filter(Boolean));
    }

    function getLeadDisplayLabel(leadId) {
        const leadCheckbox = document.querySelector(`.lead-select-checkbox[data-lead-id="${leadId}"]`);
        if (leadCheckbox && String(leadCheckbox.dataset.leadName || '').trim()) {
            return leadCheckbox.dataset.leadName.trim();
        }

        return `Lead ${String(leadId).slice(-6)}`;
    }

    function updateBulkSelectionUI() {
        const selectedCount = selectedLeadIds.size;
        const visibleLeadIds = getVisibleLeadIds();
        const selectAllLeads = document.getElementById('selectAllLeads');
        let selectedOnPage = 0;

        visibleLeadIds.forEach((leadId) => {
            if (selectedLeadIds.has(leadId)) {
                selectedOnPage += 1;
            }
        });

        if (bulkSelectedCount) {
            bulkSelectedCount.textContent = `Page: ${selectedOnPage} · All: ${selectedCount}`;
        }

        if (bulkAssignPanel) {
            bulkAssignPanel.classList.toggle('hidden', selectedCount === 0);
        }

        if (bulkAssignBtn) {
            bulkAssignBtn.disabled = selectedCount === 0;
        }

        const allSelected = visibleLeadIds.size > 0 && Array.from(visibleLeadIds).every((leadId) => selectedLeadIds.has(leadId));

        if (selectAllLeads) {
            selectAllLeads.checked = allSelected;
            selectAllLeads.indeterminate = !allSelected && selectedOnPage > 0;
        }

        persistBulkSelection();
    }

    function syncLeadCheckboxState(leadId, checked) {
        if (!leadId) {
            return;
        }

        const matchingCheckboxes = document.querySelectorAll(`.lead-select-checkbox[data-lead-id="${leadId}"]`);
        matchingCheckboxes.forEach((checkbox) => {
            checkbox.checked = checked;
        });
    }

    function bindLeadSelectionEvents() {
        const checkboxes = getLeadSelectionCheckboxes();
        const selectAllLeads = document.getElementById('selectAllLeads');

        checkboxes.forEach((checkbox) => {
            const leadId = checkbox.dataset.leadId;
            if (selectedLeadIds.has(leadId)) {
                checkbox.checked = true;
            }

            if (checkbox.dataset.bulkBound === '1') {
                return;
            }
            checkbox.dataset.bulkBound = '1';

            checkbox.addEventListener('change', () => {
                const id = checkbox.dataset.leadId;
                if (!id) {
                    return;
                }

                if (checkbox.checked) {
                    selectedLeadIds.add(id);
                } else {
                    selectedLeadIds.delete(id);
                }

                syncLeadCheckboxState(id, checkbox.checked);
                updateBulkSelectionUI();
            });
        });

        if (selectAllLeads) {
            if (selectAllLeads.dataset.bulkBound !== '1') {
                selectAllLeads.dataset.bulkBound = '1';
                selectAllLeads.addEventListener('change', () => {
                    const shouldSelect = selectAllLeads.checked;
                    const liveCheckboxes = getLeadSelectionCheckboxes();

                    liveCheckboxes.forEach((checkbox) => {
                        const id = checkbox.dataset.leadId;
                        if (!id) {
                            return;
                        }

                        if (shouldSelect) {
                            selectedLeadIds.add(id);
                        } else {
                            selectedLeadIds.delete(id);
                        }

                        syncLeadCheckboxState(id, shouldSelect);
                    });

                    updateBulkSelectionUI();
                });
            }
        }

        if (bulkClearSelectionBtn) {
            if (bulkClearSelectionBtn.dataset.bulkBound === '1') {
                updateBulkSelectionUI();
            } else {
                bulkClearSelectionBtn.dataset.bulkBound = '1';
                bulkClearSelectionBtn.addEventListener('click', () => {
                    selectedLeadIds.clear();
                    getLeadSelectionCheckboxes().forEach((checkbox) => {
                        checkbox.checked = false;
                    });
                    updateBulkSelectionUI();
                });
            }
        }

        if (bulkClearPageSelectionBtn) {
            if (bulkClearPageSelectionBtn.dataset.bulkBound === '1') {
                updateBulkSelectionUI();
            } else {
                bulkClearPageSelectionBtn.dataset.bulkBound = '1';
                bulkClearPageSelectionBtn.addEventListener('click', () => {
                    const visibleLeadIds = getVisibleLeadIds();

                    visibleLeadIds.forEach((leadId) => {
                        selectedLeadIds.delete(leadId);
                        syncLeadCheckboxState(leadId, false);
                    });

                    updateBulkSelectionUI();
                });
            }
        }

        updateBulkSelectionUI();
    }

    function hasOpenModal() {
        const modalIds = [
            'leadModal',
            'editLeadModal',
            'deleteLeadModal',
            'requestLeadInactiveModal',
            'restoreLeadModal',
            'rejectLeadRequestModal',
            'bulkAssignConfirmModal',
            'viewLeadModal'
        ];

        return modalIds.some((modalId) => {
            const modal = document.getElementById(modalId);
            return modal && !modal.classList.contains('hidden') && modal.style.display !== 'none';
        });
    }

    async function softRefreshLeadSections() {
        if (hasOpenModal()) {
            return false;
        }

        const currentScrollY = window.scrollY;
        const mainScrollContainer = document.querySelector('div.flex-1.flex.flex-col.overflow-y-auto');
        const mainScrollTop = mainScrollContainer ? mainScrollContainer.scrollTop : 0;

        try {
            const response = await fetch(window.location.href, {
                method: 'GET',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            });

            if (!response.ok) {
                return false;
            }

            const html = await response.text();
            const parser = new DOMParser();
            const nextDocument = parser.parseFromString(html, 'text/html');
            const nextVersionState = nextDocument.getElementById('leadsVersionState');
            if (nextVersionState) {
                currentLeadsVersion = String(nextVersionState.value || '');
                if (leadsVersionStateElement) {
                    leadsVersionStateElement.value = currentLeadsVersion;
                }
            }
            const sectionIds = [
                'leads-stats-section',
                'leads-table-section',
                'mobile-lead-cards',
                'leads-pagination-section'
            ];

            let replacedAnySection = false;

            sectionIds.forEach((sectionId) => {
                const currentSection = document.getElementById(sectionId);
                const nextSection = nextDocument.getElementById(sectionId);

                if (!currentSection || !nextSection) {
                    return;
                }

                if (currentSection.innerHTML !== nextSection.innerHTML) {
                    currentSection.innerHTML = nextSection.innerHTML;
                    replacedAnySection = true;
                }
            });

            if (!replacedAnySection) {
                return false;
            }

            selectedLeadIds.forEach((leadId) => {
                const checkbox = document.querySelector(`.lead-select-checkbox[data-lead-id="${leadId}"]`);
                if (!checkbox) {
                    selectedLeadIds.delete(leadId);
                }
            });

            bindLeadSelectionEvents();
            updateBulkSelectionUI();
            window.scrollTo({ top: currentScrollY, behavior: 'auto' });
            if (mainScrollContainer) {
                mainScrollContainer.scrollTop = mainScrollTop;
            }
            return true;
        } catch (error) {
            return false;
        }
    }

    function getSelectedAssigneeName() {
        if (!bulkAssignUser) {
            return 'Unassigned';
        }

        const selectedOption = bulkAssignUser.options[bulkAssignUser.selectedIndex];
        return selectedOption ? selectedOption.textContent.trim() : 'Unassigned';
    }

    function openBulkAssignConfirmModal() {
        if (!bulkAssignConfirmModal) {
            submitBulkLeadAssign();
            return;
        }

        const totalSelected = selectedLeadIds.size;
        const visibleLeadIds = getVisibleLeadIds();
        let selectedOnPage = 0;

        visibleLeadIds.forEach((leadId) => {
            if (selectedLeadIds.has(leadId)) {
                selectedOnPage += 1;
            }
        });

        if (bulkAssignConfirmSummary) {
            bulkAssignConfirmSummary.textContent = `You are going to assign ${totalSelected} lead(s) in total. ${selectedOnPage} selected on this page.`;
        }

        if (bulkAssignConfirmAssignee) {
            bulkAssignConfirmAssignee.textContent = getSelectedAssigneeName();
        }

        if (bulkAssignPreviewList) {
            bulkAssignPreviewList.innerHTML = '';

            const selectedLeadIdList = Array.from(selectedLeadIds);
            const previewLimit = 8;
            const previewItems = selectedLeadIdList.slice(0, previewLimit);

            previewItems.forEach((leadId) => {
                const item = document.createElement('li');
                item.className = 'rounded border border-slate-200 px-2 py-1';
                item.textContent = getLeadDisplayLabel(leadId);
                bulkAssignPreviewList.appendChild(item);
            });

            if (bulkAssignPreviewMeta) {
                if (selectedLeadIdList.length > previewLimit) {
                    bulkAssignPreviewMeta.textContent = `+${selectedLeadIdList.length - previewLimit} more selected lead(s)`;
                } else {
                    bulkAssignPreviewMeta.textContent = `${selectedLeadIdList.length} lead(s) selected`;
                }
            }
        }

        bulkAssignConfirmModal.classList.remove('hidden');
        lockBodyScroll();
    }

    function closeBulkAssignConfirmModal() {
        if (!bulkAssignConfirmModal) {
            return;
        }

        bulkAssignConfirmModal.classList.add('hidden');
        unlockBodyScroll();
    }

    async function submitBulkLeadAssign() {
        if (!bulkAssignBtn || !bulkAssignUser || selectedLeadIds.size === 0) {
            return;
        }

        const previousLabel = bulkAssignBtn.textContent;
        bulkAssignBtn.disabled = true;
        bulkAssignBtn.textContent = 'Assigning...';

        try {
            const payload = new URLSearchParams();
            payload.set('assignedUser', bulkAssignUser.value || '');
            selectedLeadIds.forEach((leadId) => {
                payload.append('leadIds', leadId);
            });

            const response = await fetch('/leads/assign-bulk', {
                method: 'POST',
                headers: {
                    'Accept': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: payload
            });

            const data = await response.json().catch(() => null);
            const message = data && data.message
                ? data.message
                : (response.ok ? 'Bulk assignment completed.' : 'Bulk assignment failed.');

            if (!response.ok) {
                showPopupMessage(message, 'error');
                return;
            }

            selectedLeadIds.clear();
            sessionStorage.removeItem(bulkSelectionStorageKey);
            showPopupMessage(message, 'success');
            await softRefreshLeadSections();
        } catch (error) {
            showPopupMessage('Server connection failed. Please try again.', 'error');
        } finally {
            bulkAssignBtn.disabled = selectedLeadIds.size === 0;
            bulkAssignBtn.textContent = previousLabel;
        }
    }

    restoreBulkSelectionFromStorage();
    bindLeadSelectionEvents();

    if (bulkAssignBtn) {
        bulkAssignBtn.addEventListener('click', openBulkAssignConfirmModal);
    }

    if (cancelBulkAssignConfirmBtn) {
        cancelBulkAssignConfirmBtn.addEventListener('click', closeBulkAssignConfirmModal);
    }

    if (closeBulkAssignConfirmModalBtn) {
        closeBulkAssignConfirmModalBtn.addEventListener('click', closeBulkAssignConfirmModal);
    }

    if (confirmBulkAssignBtn) {
        confirmBulkAssignBtn.addEventListener('click', async () => {
            closeBulkAssignConfirmModal();
            await submitBulkLeadAssign();
        });
    }

    if (bulkAssignConfirmModal) {
