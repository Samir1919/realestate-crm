    function openViewModal(lead) {
        const modal = document.getElementById('viewLeadModal');
        const modalPanel = modal ? modal.children[0] : null;
        if (!modal || !modalPanel) return;

        const formatValue = (value) => value || '—';
        const formatDate = (value) => {
            if (!value) return '—';
            try {
                return new Date(value).toLocaleDateString('en-GB', {
                    day: '2-digit',
                    month: 'short',
                    year: 'numeric'
                });
            } catch (error) {
                return value;
            }
        };

        document.getElementById('view_referenceNumber').textContent = formatValue(lead.referenceNumber || lead.leadNumber || lead._id);
        document.getElementById('view_customerName').textContent = formatValue(lead.customerName);
        document.getElementById('view_phone').textContent = formatValue(lead.phone);
        document.getElementById('view_preferredLocation').textContent = formatValue(lead.preferredLocation);
        document.getElementById('view_propertyType').textContent = formatValue(lead.propertyType);
        document.getElementById('view_budget').textContent = `৳${lead.budgetMin || 0} - ৳${lead.budgetMax || 0}`;
        document.getElementById('view_preferredSize').textContent = formatValue(lead.preferredSize);
        document.getElementById('view_bedrooms').textContent = formatValue(lead.bedrooms);
        document.getElementById('view_purpose').textContent = formatValue(lead.purpose);
        document.getElementById('view_assignedUser').textContent = formatValue(lead.assignedUser && lead.assignedUser.name ? lead.assignedUser.name : 'Unassigned');
        document.getElementById('view_source').textContent = formatValue(lead.source);
        document.getElementById('view_priority').textContent = formatValue(lead.priority);
        document.getElementById('view_leadType').textContent = formatValue((lead.leadType || 'good').toUpperCase());
        document.getElementById('view_status').textContent = formatValue(lead.status);
        document.getElementById('view_isActive').textContent = lead.isActive === false ? 'Inactive' : 'Active';
        document.getElementById('view_followUpDate').textContent = formatDate(lead.followUpDate);
        document.getElementById('view_messageNote').textContent = formatValue(lead.messageNote);

        const requestStatus = lead.inactiveRequest && lead.inactiveRequest.status ? lead.inactiveRequest.status : 'none';
        const requestStatusBadge = document.getElementById('view_requestStatus');
        const requestSummary = document.getElementById('view_requestSummary');
        const requestStatusMap = {
            pending: {
                label: 'Pending Review',
                className: 'inline-flex px-2.5 py-1 rounded-full text-xs font-semibold border bg-amber-100 text-amber-800 border-amber-200'
            },
            approved: {
                label: 'Approved',
                className: 'inline-flex px-2.5 py-1 rounded-full text-xs font-semibold border bg-emerald-100 text-emerald-800 border-emerald-200'
            },
            rejected: {
                label: 'Rejected',
                className: 'inline-flex px-2.5 py-1 rounded-full text-xs font-semibold border bg-rose-100 text-rose-800 border-rose-200'
            },
            none: {
                label: 'No Request',
                className: 'inline-flex px-2.5 py-1 rounded-full text-xs font-semibold border bg-slate-100 text-slate-700 border-slate-200'
            }
        };
        const requestState = requestStatusMap[requestStatus] || requestStatusMap.none;

        if (requestStatusBadge) {
            requestStatusBadge.textContent = requestState.label;
            requestStatusBadge.className = requestState.className;
        }

        if (requestSummary) {
            if (requestStatus === 'none') {
                requestSummary.textContent = 'No inactive request history yet.';
            } else if (requestStatus === 'pending') {
                requestSummary.textContent = 'Waiting for admin review.';
            } else if (requestStatus === 'approved') {
                requestSummary.textContent = 'Admin approved the inactive request.';
            } else {
                requestSummary.textContent = 'Admin reviewed and rejected the inactive request.';
            }
        }

        document.getElementById('view_requestedBy').textContent = formatValue(lead.inactiveRequest && lead.inactiveRequest.requestedByName);
        document.getElementById('view_requestedAt').textContent = formatDate(lead.inactiveRequest && lead.inactiveRequest.requestedAt);
        document.getElementById('view_requestNote').textContent = formatValue(lead.inactiveRequest && lead.inactiveRequest.note);
        document.getElementById('view_reviewedBy').textContent = formatValue(lead.inactiveRequest && lead.inactiveRequest.reviewedByName);
        document.getElementById('view_reviewedAt').textContent = formatDate(lead.inactiveRequest && lead.inactiveRequest.reviewedAt);
        document.getElementById('view_reviewNote').textContent = formatValue(lead.inactiveRequest && lead.inactiveRequest.reviewNote);

        modal.classList.remove('hidden');
        modal.style.display = 'flex';
        modalPanel.classList.remove('scale-95');
        lockBodyScroll();
    }

    function closeViewModal() {
        const modal = document.getElementById('viewLeadModal');
        const modalPanel = modal ? modal.children[0] : null;
        if (!modal || !modalPanel) return;
        modalPanel.classList.add('scale-95');
        setTimeout(() => {
            modal.classList.add('hidden');
            modal.style.display = 'none';
            unlockBodyScroll();
