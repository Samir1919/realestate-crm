    function openDeleteModal(lead) {
        const modal = document.getElementById('deleteLeadModal');
        const form = document.getElementById('deleteLeadForm');
        const modalPanel = modal ? modal.children[0] : null;
        const title = document.getElementById('deleteLeadModalTitle');
        const description = document.getElementById('deleteLeadModalDescription');
        const submitButton = document.getElementById('deleteLeadSubmitBtn');
        const reviewNote = document.getElementById('deleteLeadReviewNote');

        if (!modal || !form || !modalPanel || !lead || !lead._id) return;

        form.action = `/leads/delete/${lead._id}`;

        const hasPendingRequest = lead.inactiveRequest && lead.inactiveRequest.status === 'pending';
        const requester = hasPendingRequest ? (lead.inactiveRequest.requestedByName || 'A sales user') : '';
        const requestNote = hasPendingRequest && lead.inactiveRequest.note ? ` Reason: ${lead.inactiveRequest.note}` : '';

        if (hasPendingRequest) {
            title.textContent = 'Approve Inactive Request';
            description.textContent = `${requester} requested admin approval to mark this lead inactive.${requestNote}`;
            submitButton.textContent = 'Approve & Inactive';
            submitButton.className = 'bg-amber-600 hover:bg-amber-700 text-white px-5 py-2 rounded-lg text-sm font-medium shadow transition';
            reviewNote.classList.remove('hidden');
        } else {
            title.textContent = 'Archive Lead';
            description.textContent = 'This will mark the lead as inactive and hide it from the default active list. You can still find it later from the inactive filter.';
            submitButton.textContent = 'Archive';
            submitButton.className = 'bg-amber-600 hover:bg-amber-700 text-white px-5 py-2 rounded-lg text-sm font-medium shadow transition';
            reviewNote.classList.add('hidden');
            reviewNote.value = '';
        }

        modal.classList.remove('hidden');
        modal.style.display = 'flex';
        modalPanel.classList.remove('scale-95');
        lockBodyScroll();
    }

