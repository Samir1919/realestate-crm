<div id="deleteLeadModal"
    class="fixed inset-0 bg-black/50 backdrop-blur-sm flex items-center justify-center hidden z-50 p-4">
    <div class="bg-white rounded-xl shadow-2xl w-full max-w-md transform transition-all scale-95 duration-300">
        <div class="flex items-center justify-between border-b border-gray-200 px-6 py-4">
            <h3 class="text-xl font-bold text-gray-800">Delete Lead</h3>
            <button type="button" onclick="closeDeleteModal()"
                class="text-gray-400 hover:text-gray-600 text-2xl font-semibold">&times;</button>
        </div>
        <form id="deleteLeadForm" method="POST" class="p-6 space-y-4">
            <p class="text-sm text-gray-600">This action cannot be undone. Do you want to delete this lead?</p>
            <div class="flex justify-end space-x-3 pt-2">
                <button type="button" onclick="closeDeleteModal()"
                    class="bg-gray-200 hover:bg-gray-300 text-gray-700 px-5 py-2 rounded-lg text-sm font-medium transition">Cancel</button>
                <button type="submit"
                    class="bg-red-600 hover:bg-red-700 text-white px-5 py-2 rounded-lg text-sm font-medium shadow transition">Delete</button>
            </div>
        </form>
    </div>
</div>

