                <p class="text-xs sm:text-sm text-slate-500 font-medium safe-truncate">Total Leads</p>
                <p class="text-2xl sm:text-3xl font-bold text-slate-900 mt-1 tabular-nums">
                    <%= totalLeads %>
                </p>
            </div>
