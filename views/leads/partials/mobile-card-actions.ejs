<% const isInactive=lead.isActive===false; %>
    <% const requestStatus=lead.inactiveRequest && lead.inactiveRequest.status ? lead.inactiveRequest.status : 'none' ;
        %>
        <% const hasPendingRequest=!isInactive && requestStatus==='pending' ; %>
            <% const canManageDeletes=canDeleteLead || (permissions && permissions.deleteLead); %>
                <button type="button"
                    class="view-lead-btn inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-xl text-sm font-semibold transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 cursor-pointer hover:bg-slate-100 text-slate-700 h-8 w-8"
                    title="View" data-lead='<%- JSON.stringify(lead) %>' onclick="openViewModalFromButton(this)">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                        class="lucide lucide-eye h-3.5 w-3.5" aria-hidden="true">
                        <path
                            d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0">
                        </path>
                        <circle cx="12" cy="12" r="3"></circle>
                    </svg>
                </button>
                <% if (canUpdateLead || (permissions && permissions.updateLead)) { %>
                    <button type="button"
                        class="edit-lead-btn inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-xl text-sm font-semibold transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 cursor-pointer hover:bg-slate-100 text-slate-700 h-8 w-8"
                        title="Edit" data-id="<%= lead._id %>" data-lead='<%- JSON.stringify(lead) %>'
                        onclick="openEditModalFromButton(this)">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
                            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                            class="lucide lucide-pencil h-3.5 w-3.5" aria-hidden="true">
                            <path
                                d="M21.174 6.812a1 1 0 0 0-3.986-3.987L3.842 16.174a2 2 0 0 0-.5.83l-1.321 4.352a.5.5 0 0 0 .623.622l4.353-1.32a2 2 0 0 0 .83-.497z">
                            </path>
                            <path d="m15 5 4 4"></path>
                        </svg>
                    </button>
                    <% } %>
                        <% if (canRequestInactive && !isInactive) { %>
                            <% if (hasPendingRequest) { %>
                                <span
                                    class="inline-flex items-center justify-center rounded-xl border border-amber-200 bg-amber-50 text-amber-700 h-8 px-2 text-[11px] font-semibold whitespace-nowrap">
                                    Pending
                                </span>
                                <% } else { %>
                                    <button type="button"
                                        class="inactive-request-btn inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-xl text-sm font-semibold transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 cursor-pointer hover:bg-amber-50 text-amber-700 h-8 w-8"
                                        title="Request Inactive" data-lead='<%- JSON.stringify(lead) %>'
                                        onclick="openRequestInactiveModalFromButton(this)">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                                            viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                            stroke-linecap="round" stroke-linejoin="round"
                                            class="lucide lucide-shield-alert h-3.5 w-3.5" aria-hidden="true">
                                            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"></path>
                                            <path d="M12 8v4"></path>
                                            <path d="M12 16h.01"></path>
                                        </svg>
                                    </button>
                                    <% } %>
                                        <% } %>
                                            <% if (isInactive && canManageDeletes) { %>
                                                <button type="button"
                                                    class="restore-lead-btn inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-xl text-sm font-semibold transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 cursor-pointer hover:bg-emerald-50 text-emerald-700 h-8 w-8"
                                                    title="Restore" data-id="<%= lead._id %>"
                                                    onclick="openRestoreModalFromButton(this)">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                                                        viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                        stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                                                        class="lucide lucide-rotate-ccw h-3.5 w-3.5" aria-hidden="true">
                                                        <path d="M3 2v6h6"></path>
                                                        <path d="M3 8a9 9 0 1 0 2.6-4.4L3 6"></path>
                                                    </svg>
                                                </button>
                                                <% } %>
                                                    <a href="tel:<%= lead.phone %>" title="Call">
                                                        <button
                                                            class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-xl text-sm font-semibold transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 cursor-pointer hover:bg-slate-100 text-slate-700 h-8 w-8">
                                                            <svg xmlns="http://www.w3.org/2000/svg" width="24"
                                                                height="24" viewBox="0 0 24 24" fill="none"
                                                                stroke="currentColor" stroke-width="2"
                                                                stroke-linecap="round" stroke-linejoin="round"
                                                                class="lucide lucide-phone h-3.5 w-3.5"
                                                                aria-hidden="true">
                                                                <path
                                                                    d="M13.832 16.568a1 1 0 0 0 1.213-.303l.355-.465A2 2 0 0 1 17 15h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2A18 18 0 0 1 2 4a2 2 0 0 1 2-2h3a2 2 0 0 1 2 2v3a2 2 0 0 1-.8 1.6l-.468.351a1 1 0 0 0-.292 1.233 14 14 0 0 0 6.392 6.384">
                                                                </path>
                                                            </svg>
                                                        </button>
                                                    </a>
                                                    <a href="https://wa.me/<%= lead.phone.replace(/[^0-9]/g, '') %>"
                                                        target="_blank" rel="noopener noreferrer" title="WhatsApp">
                                                        <button
                                                            class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-xl text-sm font-semibold transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 cursor-pointer hover:bg-slate-100 text-slate-700 h-8 w-8">
                                                            <svg xmlns="http://www.w3.org/2000/svg" width="24"
                                                                height="24" viewBox="0 0 24 24" fill="none"
                                                                stroke="currentColor" stroke-width="2"
                                                                stroke-linecap="round" stroke-linejoin="round"
                                                                class="lucide lucide-message-circle h-3.5 w-3.5 text-emerald-600"
                                                                aria-hidden="true">
                                                                <path
                                                                    d="M2.992 16.342a2 2 0 0 1 .094 1.167l-1.065 3.29a1 1 0 0 0 1.236 1.168l3.413-.998a2 2 0 0 1 1.099.092 10 10 0 1 0-4.777-4.719">
                                                                </path>
                                                            </svg>
                                                        </button>
                                                    </a>
                                                    <% if (canManageDeletes) { %>
                                                        <% if (hasPendingRequest) { %>
                                                            <button type="button"
                                                                class="delete-lead-btn inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-xl text-sm font-semibold transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 cursor-pointer hover:bg-amber-50 text-amber-700 h-8 w-8"
                                                                title="Approve Inactive Request"
                                                                data-lead='<%- JSON.stringify(lead) %>'
                                                                onclick="openDeleteModalFromButton(this)">
                                                                <svg xmlns="http://www.w3.org/2000/svg" width="24"
                                                                    height="24" viewBox="0 0 24 24" fill="none"
                                                                    stroke="currentColor" stroke-width="2"
                                                                    stroke-linecap="round" stroke-linejoin="round"
                                                                    class="lucide lucide-check h-3.5 w-3.5 text-amber-700"
                                                                    aria-hidden="true">
                                                                    <path d="M20 6 9 17l-5-5"></path>
                                                                </svg>
                                                            </button>
                                                            <button type="button"
                                                                class="reject-inactive-request-btn inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-xl text-sm font-semibold transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 cursor-pointer hover:bg-rose-50 text-rose-700 h-8 w-8"
                                                                title="Reject Inactive Request"
                                                                data-lead='<%- JSON.stringify(lead) %>'
                                                                onclick="openRejectLeadRequestModalFromButton(this)">
                                                                <svg xmlns="http://www.w3.org/2000/svg" width="24"
                                                                    height="24" viewBox="0 0 24 24" fill="none"
                                                                    stroke="currentColor" stroke-width="2"
                                                                    stroke-linecap="round" stroke-linejoin="round"
                                                                    class="lucide lucide-x h-3.5 w-3.5 text-rose-700"
                                                                    aria-hidden="true">
                                                                    <path d="M18 6 6 18"></path>
                                                                    <path d="m6 6 12 12"></path>
                                                                </svg>
                                                            </button>
                                                            <% } else { %>
                                                                <button type="button"
                                                                    class="delete-lead-btn inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-xl text-sm font-semibold transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 cursor-pointer hover:bg-slate-100 text-slate-700 h-8 w-8"
                                                                    title="Archive"
                                                                    data-lead='<%- JSON.stringify(lead) %>'
                                                                    onclick="openDeleteModalFromButton(this)">
                                                                    <svg xmlns="http://www.w3.org/2000/svg" width="24"
                                                                        height="24" viewBox="0 0 24 24" fill="none"
                                                                        stroke="currentColor" stroke-width="2"
                                                                        stroke-linecap="round" stroke-linejoin="round"
                                                                        class="lucide lucide-trash-2 h-3.5 w-3.5 text-red-500"
                                                                        aria-hidden="true">
                                                                        <path d="M10 11v6"></path>
                                                                        <path d="M14 11v6"></path>
                                                                        <path
                                                                            d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6">
                                                                        </path>
                                                                        <path d="M3 6h18"></path>
                                                                        <path
                                                                            d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2">
                                                                        </path>
                                                                    </svg>
                                                                </button>
                                                                <% } %>
                                                                    <% } %>